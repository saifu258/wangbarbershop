<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TV Display - WANG BARBERSHOP</title>
    
    <!-- Tailwind CSS (via CDN) -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- FontAwesome 6 (via CDN) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Google Fonts (Kanit) -->
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- Firebase SDK v9 (Compat version via CDN) -->
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-firestore-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>
    
    <!-- Custom Firebase Config -->
    <script src="/js/firebase_config.js"></script>

    <style>
        body {
            font-family: 'Kanit', sans-serif;
            overflow: hidden; /* ปิด Scrollbar สำหรับจอ TV */
        }
        .neon-green {
            text-shadow: 0 0 5px rgba(34, 197, 94, 0.8), 0 0 15px rgba(34, 197, 94, 0.5);
        }
        .marquee-container {
            overflow: hidden;
            white-space: nowrap;
        }
        .marquee-content {
            display: inline-block;
            padding-left: 100%;
            animation: marquee 20s linear infinite;
        }
        @keyframes marquee {
            0% { transform: translate(0, 0); }
            100% { transform: translate(-100%, 0); }
        }
    </style>
</head>
<body class="bg-slate-900 text-white h-screen flex flex-col relative select-none">

    <!-- Error Banner (แสดงเมื่อ Firebase มีปัญหา) -->
    <div id="firebaseErrorBanner" class="hidden bg-red-600 text-white text-center py-3 px-4 font-bold shadow-lg z-[100] relative">
        <i class="fa-solid fa-triangle-exclamation mr-2 text-xl"></i> 
        ระบบไม่สามารถเชื่อมต่อฐานข้อมูลได้ (รันในโหมดจำลอง / ไม่มี Firebase Config)
    </div>

    <!-- ปุ่มอนุญาตเปิดระบบเสียง (Browser Policy) -->
    <button id="startAudioBtn" class="absolute top-6 right-6 bg-green-600 hover:bg-green-500 text-white px-5 py-3 rounded-xl text-sm z-50 flex items-center gap-2 shadow-lg hover:shadow-green-500/30 transition-all duration-300 font-bold border border-green-400">
        <i class="fa-solid fa-volume-high text-lg"></i> เปิดระบบเสียง/เริ่มระบบ
    </button>

    <!-- Header & Branding -->
    <header class="p-6 sm:p-8 flex justify-between items-center border-b border-slate-800 bg-slate-900/80 backdrop-blur-md">
        <div class="flex items-center gap-5">
            <div class="bg-blue-600 p-4 rounded-2xl shadow-[0_0_20px_rgba(37,99,235,0.4)]">
                <i class="fa-solid fa-scissors text-4xl text-white transform -rotate-45"></i>
            </div>
            <div>
                <h1 class="font-black text-5xl tracking-widest text-white">WANG <span class="text-blue-500">BARBER</span></h1>
                <p class="text-slate-400 text-sm tracking-[0.3em] uppercase mt-1 font-semibold">Premium Barbershop</p>
            </div>
        </div>
        <div class="text-right">
            <div id="clock" class="text-5xl font-bold text-slate-100 tracking-wider font-mono">00:00:00</div>
            <div id="date" class="text-slate-400 text-lg mt-2 font-medium">วันเดือนปี</div>
        </div>
    </header>

    <!-- Main Content Display -->
    <main class="flex-grow grid grid-cols-2 p-10 gap-0">
        
        <!-- ฝั่งซ้าย: ข้อมูลช่าง และ สถานะ -->
        <div class="flex flex-col justify-center items-end pr-16 border-r-2 border-slate-800">
            <!-- ป้ายชื่อช่าง -->
            <div class="bg-slate-800 px-10 py-5 rounded-3xl mb-12 border border-slate-700 shadow-xl shadow-slate-900/50">
                <h2 class="text-3xl font-medium text-slate-400">ช่องบริการ / ช่าง</h2>
                <h3 id="currentBarber" class="text-6xl font-bold text-blue-400 mt-2">ว่าง</h3>
            </div>
            
            <!-- ไฟกระพริบ "กำลังเรียกคิว" -->
            <div class="flex items-center gap-5">
                <span class="relative flex h-8 w-8">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-8 w-8 bg-green-500 shadow-[0_0_15px_#22c55e]"></span>
                </span>
                <h3 class="text-6xl font-black text-green-400 tracking-wide">กำลังเรียกคิว</h3>
            </div>
        </div>

        <!-- ฝั่งขวา: หมายเลขคิว -->
        <div class="flex flex-col justify-center items-start pl-16">
            <div class="relative w-full overflow-hidden">
                <!-- หมายเลขคิวใหญ่พิเศษและเรืองแสงแบบคมชัด (Crisp Glow) ปรับขนาดลงเพื่อไม่ให้ล้นจอ -->
                <div id="currentQueue" class="text-[10rem] xl:text-[12rem] leading-none font-black text-white neon-green tracking-wider transition-all duration-300 truncate">
                    ---
                </div>
            </div>
            <div class="mt-8 bg-slate-800/80 px-10 py-5 rounded-3xl border border-slate-700 shadow-xl max-w-full">
                <p class="text-3xl text-slate-300 font-medium truncate">ชื่อลูกค้า: <span id="currentCustomer" class="text-white font-bold text-4xl ml-4">-</span></p>
            </div>
        </div>
    </main>

    <!-- แถบด้านล่าง: คิวรอถัดไป (Marquee) -->
    <footer class="bg-slate-950 border-t-4 border-slate-800 h-24 flex items-center relative overflow-hidden">
        <!-- ป้ายหัวข้อแถบวิ่ง (Fixed) -->
        <div class="absolute left-0 top-0 bottom-0 bg-blue-600 text-white font-bold px-8 py-2 z-20 shadow-xl flex items-center gap-4 text-3xl">
            <i class="fa-solid fa-users"></i> คิวรอถัดไป
            <!-- สามเหลี่ยมชี้ขวา -->
            <div class="absolute right-[-24px] top-0 bottom-0 w-0 h-0 border-t-[48px] border-t-transparent border-l-[24px] border-l-blue-600 border-b-[48px] border-b-transparent"></div>
        </div>
        
        <!-- แถบวิ่ง (Marquee) -->
        <div class="marquee-container w-full h-full flex items-center pl-[280px]">
            <div id="upcomingQueues" class="marquee-content text-4xl font-medium text-slate-300">
                ไม่มีคิวรอในขณะนี้
            </div>
        </div>
    </footer>

    <!-- Script ควบคุมการทำงาน -->
    <script>
        // 1. นาฬิกาแบบ Real-time
        function updateClock() {
            const now = new Date();
            document.getElementById('clock').innerText = now.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
            document.getElementById('date').innerText = now.toLocaleDateString('th-TH', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        }
        setInterval(updateClock, 1000);
        updateClock();

        // 2. ระบบเสียง Speech Synthesis
        let audioEnabled = false;
        const startAudioBtn = document.getElementById('startAudioBtn');

        startAudioBtn.addEventListener('click', () => {
            audioEnabled = true;
            const unlockUtterance = new SpeechSynthesisUtterance('');
            window.speechSynthesis.speak(unlockUtterance);
            
            startAudioBtn.innerHTML = '<i class="fa-solid fa-check text-xl"></i> ระบบเสียงทำงานแล้ว';
            startAudioBtn.classList.replace('bg-green-600', 'bg-slate-800');
            startAudioBtn.classList.replace('border-green-400', 'border-slate-700');
            startAudioBtn.classList.replace('text-white', 'text-green-400');
            
            setTimeout(() => {
                startAudioBtn.style.opacity = '0';
                setTimeout(() => startAudioBtn.style.display = 'none', 500);
            }, 2000);
        });

        // 3. Logic อัปเดตหน้าจอและเล่นเสียง
        let lastSpokenQueueId = null;

        function renderCalling(booking) {
            const qElem = document.getElementById('currentQueue');
            if (booking) {
                qElem.innerText = booking.queueId || 'ไม่ระบุคิว';
                document.getElementById('currentBarber').innerText = booking.barber || 'ช่างทั่วไป';
                document.getElementById('currentCustomer').innerText = booking.firstName || 'ลูกค้าไม่ได้ระบุชื่อ';
                
                // ตรวจสอบ lastSpokenQueueId เพื่อไม่ให้เสียงพูดซ้ำรัวๆ หากข้อมูลเดิมถูกอัปเดต
                if (booking.queueId && booking.queueId !== lastSpokenQueueId) {
                    lastSpokenQueueId = booking.queueId;
                    
                    if (audioEnabled && window.speechSynthesis) {
                        const queueSpaced = booking.queueId.split('').join(' ');
                        const msg = new SpeechSynthesisUtterance("ขอเชิญคิว " + queueSpaced + " ค่ะ");
                        msg.lang = 'th-TH';
                        msg.rate = 0.8;
                        msg.pitch = 1.1;
                        window.speechSynthesis.speak(msg);
                    }
                    
                    qElem.classList.add('animate-pulse');
                    setTimeout(() => qElem.classList.remove('animate-pulse'), 3000);
                }
            } else {
                qElem.innerText = '---';
                document.getElementById('currentBarber').innerText = 'รอคิวถัดไป';
                document.getElementById('currentCustomer').innerText = '-';
            }
        }

        function renderUpcoming(bookings) {
            const container = document.getElementById('upcomingQueues');
            if (bookings && bookings.length > 0) {
                // สร้าง HTML Text
                const htmlText = bookings.map(b => 
                    `<span class="text-green-400 font-bold">${b.queueId || 'ไม่ระบุคิว'}</span> (${b.firstName || 'ลูกค้า'})`
                ).join(' &nbsp;&nbsp;&nbsp;&nbsp;|&nbsp;&nbsp;&nbsp;&nbsp; ');
                container.innerHTML = htmlText;
            } else {
                container.innerHTML = 'ไม่มีคิวรอในขณะนี้';
            }
        }

        // 4. ดึงข้อมูลจาก Firebase (Real-time)
        let unsubscribeCalling = null;
        let unsubscribePending = null;

        if (typeof db !== 'undefined' && db !== null) {
            
            // 4.1 Listener: ดึงคิวที่ status = "calling" หรือ "serving" ล่าสุด
            unsubscribeCalling = db.collection("bookings")
                .where("status", "in", ["calling", "serving"])
                .onSnapshot((snapshot) => {
                    if (!snapshot.empty) {
                        const callingBookings = snapshot.docs.map(doc => doc.data());
                        
                        // [Data Safety] เรียงลำดับฝั่ง Client (JS) เพื่อเลี่ยงปัญหา Firestore Index Requirement
                        callingBookings.sort((a,b) => {
                            const timeA = a.updatedAt?.toDate ? a.updatedAt.toDate().getTime() : new Date(a.updatedAt || 0).getTime();
                            const timeB = b.updatedAt?.toDate ? b.updatedAt.toDate().getTime() : new Date(b.updatedAt || 0).getTime();
                            return timeB - timeA; // Descending (ใหม่ไปเก่า)
                        });
                        
                        // ดึงคิวที่เรียกบล่าสุดมาแสดง
                        renderCalling(callingBookings[0]);
                    } else {
                        renderCalling(null);
                    }
                }, (error) => {
                    console.error("Firebase Snapshot Error (Calling): ", error);
                });

            // 4.2 Listener: ดึงคิวที่ status = "pending" (คิวรอ)
            unsubscribePending = db.collection("bookings")
                .where("status", "==", "pending")
                .onSnapshot((snapshot) => {
                    const pendingList = snapshot.docs.map(doc => doc.data());
                    
                    // [Data Safety] เรียงลำดับฝั่ง Client (JS) เพื่อเลี่ยงปัญหา Firestore Index Requirement
                    pendingList.sort((a,b) => {
                        const timeA = a.createdAt?.toDate ? a.createdAt.toDate().getTime() : new Date(a.createdAt || 0).getTime();
                        const timeB = b.createdAt?.toDate ? b.createdAt.toDate().getTime() : new Date(b.createdAt || 0).getTime();
                        return timeA - timeB; // Ascending (เก่าไปใหม่)
                    });
                    
                    // แสดงผลแค่ 10 คิวถัดไป
                    renderUpcoming(pendingList.slice(0, 10));
                }, (error) => {
                    console.error("Firebase Snapshot Error (Pending): ", error);
                });

            // [Memory Leak Prevention] ป้องกัน Memory leak เมื่อออกจากหน้าหรือรีเฟรช
            window.addEventListener('beforeunload', () => {
                if (unsubscribeCalling) unsubscribeCalling();
                if (unsubscribePending) unsubscribePending();
            });

        } else {
            // โหมดจำลองข้อมูล (Mock Mode) ในกรณีที่ยังไม่ได้ใส่ Firebase Config
            console.warn("⚠️ ไม่พบฐานข้อมูล Firebase: ระบบรันในโหมดจำลอง (Mock Mode)");
            document.getElementById('firebaseErrorBanner').classList.remove('hidden');
            
            // ข้อมูลจำลอง
            renderCalling({ queueId: 'A125', barber: 'Barber 1', firstName: 'สมชาย' });
            
            renderUpcoming([
                { queueId: 'A126', firstName: 'สมหญิง' },
                { queueId: 'A127', firstName: 'วิชัย' },
                { queueId: 'A128', firstName: 'นพดล' },
                { queueId: 'A129', firstName: 'มาริโอ้' }
            ]);

            // จำลองการเรียกคิวใหม่หลังจากผ่านไป 10 วินาที
            setTimeout(() => {
                renderCalling({ queueId: 'A126', barber: 'Barber 2', firstName: 'สมหญิง' });
                
                renderUpcoming([
                    { queueId: 'A127', firstName: 'วิชัย' },
                    { queueId: 'A128', firstName: 'นพดล' },
                    { queueId: 'A129', firstName: 'มาริโอ้' }
                ]);
            }, 10000);
        }
    </script>
</body>
</html>
