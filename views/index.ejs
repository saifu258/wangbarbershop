<script>
    // ดึงค่าการควบคุมการส่งฟอร์มเพื่อป้องกัน Double Submission
    let isSubmitting = false;

    // เลื่อนหน้าจอไปที่ฟอร์มจองคิว
    function scrollToBookingForm() {
        const section = document.getElementById('bookingFormSection');
        if (section) {
            section.scrollIntoView({ behavior: 'smooth' });
        }
    }

    // จัดการส่งฟอร์มจองคิว
    document.getElementById('bookingForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        if (isSubmitting) return;

        let queueId = 'A001';

        // ดึงข้อมูลฟอร์ม
        const firstName = document.getElementById('firstName').value.trim();
        const lastName = document.getElementById('lastName').value.trim();
        const phone = document.getElementById('phone').value.trim();
        
        // Data Safety & Validation
        if (!firstName || !phone) {
            if (typeof Swal !== 'undefined') Swal.fire({ icon: 'warning', title: 'ข้อมูลไม่ครบถ้วน', text: 'กรุณากรอกข้อมูลที่จำเป็น (ชื่อ และเบอร์โทร) ให้ครบถ้วน' });
            else alert("❌ กรุณากรอกข้อมูลที่จำเป็น (ชื่อ และเบอร์โทร) ให้ครบถ้วน");
            return;
        }

        const nameRegex = /^[a-zA-Zก-๙\s]+$/;
        if (!nameRegex.test(firstName) || (lastName && !nameRegex.test(lastName))) {
            if (typeof Swal !== 'undefined') Swal.fire({ icon: 'warning', title: 'รูปแบบชื่อไม่ถูกต้อง', text: 'ชื่อและนามสกุลต้องประกอบด้วยตัวอักษรเท่านั้น (ห้ามมีตัวเลขหรือสัญลักษณ์พิเศษ)' });
            else alert("❌ ชื่อและนามสกุลต้องประกอบด้วยตัวอักษรเท่านั้น (ห้ามมีตัวเลขหรือสัญลักษณ์พิเศษ)");
            return;
        }

        const phoneRegex = /^0[0-9]{8,9}$/;
        if (!phoneRegex.test(phone)) {
            if (typeof Swal !== 'undefined') Swal.fire({ icon: 'warning', title: 'เบอร์โทรศัพท์ไม่ถูกต้อง', text: 'รูปแบบเบอร์โทรศัพท์ต้องขึ้นต้นด้วย 0 และมีตัวเลข 9-10 หลัก' });
            else alert("❌ รูปแบบเบอร์โทรศัพท์ไม่ถูกต้อง (ต้องขึ้นต้นด้วย 0 และมีตัวเลข 9-10 หลัก)");
            return;
        }
        
        const serviceValue = document.getElementById('service').value;
        const [serviceName, servicePriceStr] = serviceValue.split('|');
        const servicePrice = Number(servicePriceStr);
        
        const barberSelect = document.getElementById('barber');
        const barberId = barberSelect.value;
        const barberName = barberSelect.options[barberSelect.selectedIndex].text;

        const submitBtn = document.querySelector('button[type="submit"]');
        const originalBtnText = submitBtn.innerHTML;
        
        // UX: ป้องกันการกดซ้ำ และแสดง Loading State
        isSubmitting = true;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> กำลังจอง...';
        submitBtn.classList.add('opacity-70', 'cursor-not-allowed');

        try {
            if (typeof db !== 'undefined' && db !== null) {
                // เรียกใช้ Backend API สำหรับจองคิว
                const response = await fetch('/api/bookings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        firstName: firstName,
                        lastName: lastName,
                        phone: phone,
                        serviceName: serviceName,
                        servicePrice: servicePrice,
                        barberId: barberId,
                        barber: barberName
                    })
                });

                const responseText = await response.text();
                let result;
                try {
                    result = JSON.parse(responseText);
                } catch (e) {
                    console.error("API returned non-JSON:", responseText);
                    throw new Error("เซิร์ฟเวอร์ตอบกลับไม่ถูกต้อง กรุณาติดต่อช่าง");
                }

                if (!response.ok || !result.success) {
                    throw new Error(result.message || "การจองคิวล้มเหลว");
                }
                
                queueId = result.queueId;

                if (typeof Swal !== 'undefined') {
                    await Swal.fire({
                        icon: 'success',
                        title: 'จองคิวสำเร็จ!',
                        html: `
                            <div class="text-left bg-gray-50 p-4 rounded-lg mt-2 border border-green-100">
                                <p class="mb-1 text-gray-700"><strong>ชื่อ:</strong> ${firstName} ${lastName}</p>
                                <p class="mb-1 text-gray-700"><strong>บริการ:</strong> ${serviceName} (${servicePrice}฿)</p>
                                <p class="mb-1 text-gray-700"><strong>ช่าง:</strong> ${barberName}</p>
                                <div class="mt-5 pt-4 border-t border-gray-200 text-center">
                                    <p class="text-sm text-gray-500 mb-1">หมายเลขคิวของคุณคือ</p>
                                    <p class="text-4xl font-black text-blue-600 tracking-wider">${queueId}</p>
                                </div>
                            </div>
                        `,
                        confirmButtonText: 'ตกลง',
                        confirmButtonColor: '#2563EB'
                    });
                } else {
                    alert(`✅ จองคิวสำเร็จ!\n\nชื่อ: ${firstName} ${lastName}\nบริการ: ${serviceName} (${servicePrice}฿)\nช่าง: ${barberName}\n\nหมายเลขคิวของคุณคือ: ${queueId}`);
                }
                
                // เคลียร์ฟอร์มเมื่อจองสำเร็จ
                document.getElementById('bookingForm').reset();
            } else {
                throw new Error("ไม่พบการเชื่อมต่อฐานข้อมูล");
            }
        } catch (error) {
            console.error("Error adding booking: ", error);
            
            if (error.code === 'permission-denied' || error.message.includes("permissions")) {
                if (typeof Swal !== 'undefined') Swal.fire({ icon: 'error', title: 'สิทธิ์ไม่เพียงพอ', text: 'เกิดข้อผิดพลาดด้านสิทธิ์การจองคิว กรุณาติดต่อช่าง' });
                else alert("❌ เกิดข้อผิดพลาดด้านสิทธิ์ (Permission Denied)");
            } else {
                if (typeof Swal !== 'undefined') Swal.fire({ icon: 'error', title: 'เกิดข้อผิดพลาด', text: 'ไม่สามารถบันทึกข้อมูลการจอง: ' + error.message });
                else alert("❌ เกิดข้อผิดพลาดในการบันทึกข้อมูล: " + error.message);
            }
        } finally {
            // คืนค่าปุ่มให้ใช้งานได้อีกครั้งเสมอ
            isSubmitting = false;
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalBtnText;
            submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
        }
    });

    // ตัวแปรเก็บฟังก์ชันการยกเลิกการติดตามข้อมูลของ Firestore
    let unsubscribeSettings = null;
    let unsubscribeServices = null;
    let unsubscribeBookings = null;
    let unsubscribeBarbers = null;

    // การแปลงชื่อเพื่อความเป็นส่วนตัว (Privacy Masking)
    function maskName(firstName, lastName) {
        let name = (firstName || '').trim();
        if (!name) return 'ลูกค้า';
        return `${name.charAt(0)}****`;
    }

    // คลาสสีสถานะคิว
    function badgeClass(status) {
        switch (status) {
            case 'pending': return 'bg-amber-100 text-amber-700 border border-amber-200';
            case 'calling': return 'bg-blue-100 text-blue-700 border border-blue-200 animate-pulse';
            case 'serving': return 'bg-purple-100 text-purple-700 border border-purple-200';
            case 'completed': return 'bg-green-100 text-green-700 border border-green-200';
            default: return 'bg-gray-100 text-gray-700 border border-gray-200';
        }
    }

    // ข้อความภาษาไทยของสถานะคิว
    function statusLabel(status) {
        switch (status) {
            case 'pending': return 'กำลังรอ';
            case 'calling': return 'กำลังเรียกคิว';
            case 'serving': return 'กำลังให้บริการ';
            case 'completed': return 'เสร็จสิ้น';
            default: return status || '-';
        }
    }

    // คำนวณวันที่ของวันนี้ในเขตเวลาท้องถิ่นลูกค้า (YYYY-MM-DD)
    function getTodayDateString() {
        const today = new Date();
        const yyyy = today.getFullYear();
        const mm = String(today.getMonth() + 1).padStart(2, '0');
        const dd = String(today.getDate()).padStart(2, '0');
        return `${yyyy}-${mm}-${dd}`;
    }

    // การโหลดและติดตามข้อมูลคิววันนี้ (เรียลไทม์)
    function initializeQueueListener() {
        if (typeof db === 'undefined' || db === null) {
            document.getElementById('queueListLoading').classList.add('hidden');
            document.getElementById('queueListError').classList.remove('hidden');
            return;
        }

        const todayStr = getTodayDateString();

        // 1. ติดตามรายการจองคิววันนี้
        unsubscribeBookings = db.collection('bookings')
            .where('date', '==', todayStr)
            .onSnapshot(snapshot => {
                document.getElementById('queueListLoading').classList.add('hidden');
                document.getElementById('queueListError').classList.add('hidden');

                const bookings = [];
                snapshot.forEach(doc => {
                    bookings.push({ id: doc.id, ...doc.data() });
                });

                // เรียงตามเวลาที่สร้างคิว (createdAt) จากเก่าไปใหม่
                bookings.sort((a, b) => {
                    const timeA = a.createdAt?.toDate ? a.createdAt.toDate().getTime() : new Date(a.createdAt || 0).getTime();
                    const timeB = b.createdAt?.toDate ? b.createdAt.toDate().getTime() : new Date(b.createdAt || 0).getTime();
                    return timeA - timeB;
                });

                // การ์ดสรุป: คิวที่กำลังรอ (pending)
                const waitingList = bookings.filter(b => b.status === 'pending');
                document.getElementById('waitingQueueCount').innerText = `${waitingList.length} คิว`;

                // การ์ดสรุป: คิวที่กำลังให้บริการ (calling หรือ serving)
                const servingList = bookings.filter(b => b.status === 'calling' || b.status === 'serving');
                if (servingList.length > 0) {
                    const servingIds = servingList.map(b => b.queueId).join(', ');
                    document.getElementById('servingQueueId').innerText = `คิว ${servingIds}`;
                } else {
                    document.getElementById('servingQueueId').innerText = '-';
                }

                // แสดงรายการคิวเฉพาะที่เปิดค้างอยู่ (pending, calling, serving)
                const activeQueues = bookings.filter(b => b.status === 'pending' || b.status === 'calling' || b.status === 'serving');
                const listItemsContainer = document.getElementById('queueListItems');
                listItemsContainer.innerHTML = '';

                if (activeQueues.length === 0) {
                    document.getElementById('queueListEmpty').classList.remove('hidden');
                } else {
                    document.getElementById('queueListEmpty').classList.add('hidden');
                    activeQueues.forEach(b => {
                        const itemHtml = `
                            <div class="bg-gray-50 hover:bg-gray-100 transition-colors border border-gray-100 rounded-xl p-4 flex justify-between items-center gap-3">
                                <div class="min-w-0">
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="font-black text-blue-600 text-lg tracking-wider">${b.queueId || 'คิว'}</span>
                                        <span class="font-semibold text-gray-800 truncate text-sm">คุณ ${maskName(b.firstName, b.lastName)}</span>
                                    </div>
                                    <div class="text-xs text-gray-500 space-y-0.5">
                                        <p><i class="fa-solid fa-list-check w-4"></i> บริการ: <span class="text-gray-700 font-medium">${b.serviceName || '-'}</span></p>
                                        <p><i class="fa-solid fa-scissors w-4"></i> ช่าง: <span class="text-gray-700 font-medium">${b.barber || '-'}</span></p>
                                    </div>
                                </div>
                                <div class="flex-shrink-0">
                                    <span class="px-3 py-1.5 rounded-full text-xs font-black shadow-sm ${badgeClass(b.status)}">
                                        ${statusLabel(b.status)}
                                    </span>
                                </div>
                            </div>
                        `;
                        listItemsContainer.insertAdjacentHTML('beforeend', itemHtml);
                    });
                }
            }, error => {
                console.error("Firestore Listen Bookings Error:", error);
                document.getElementById('queueListLoading').classList.add('hidden');
                document.getElementById('queueListError').classList.remove('hidden');
            });

        // 2. ติดตามจำนวนช่างที่เปิดรับคิว (active)
        unsubscribeBarbers = db.collection('users')
            .where('role', '==', 'barber')
            .where('status', '==', 'active')
            .onSnapshot(snapshot => {
                document.getElementById('activeBarbersCount').innerText = `${snapshot.size} คน`;
            }, error => {
                console.error("Firestore Listen Barbers Error:", error);
                document.getElementById('activeBarbersCount').innerText = '-';
            });
    }

    function retryLoadQueues() {
        document.getElementById('queueListLoading').classList.remove('hidden');
        document.getElementById('queueListError').classList.add('hidden');
        initializeQueueListener();
    }

    // การเชื่อมต่อและโหลดข้อมูลร้านค้าเมื่อเริ่มต้นหน้า
    window.addEventListener('DOMContentLoaded', async () => {
        const barberSelect = document.getElementById('barber');
        
        // 1. ดึงรายชื่อช่างตัดผม (API)
        let apiSuccess = false;
        try {
            const res = await fetch('/api/barbers');
            if (res.ok) {
                const result = await res.json();
                if (result.success) {
                    apiSuccess = true;
                    if (result.data.length > 0) {
                        barberSelect.innerHTML = '<option value="" disabled selected>-- เลือกช่าง --</option>';
                        result.data.forEach(barber => {
                            const option = document.createElement('option');
                            option.value = barber.id;
                            option.textContent = barber.name;
                            barberSelect.appendChild(option);
                        });
                    } else {
                        barberSelect.innerHTML = '<option value="" disabled selected>-- ไม่มีช่างพร้อมให้บริการ --</option>';
                    }
                }
            }
        } catch (error) {
            console.error("API Fetch Error:", error);
        }

        // Fallback: ใช้ Firebase Client SDK ดึงข้อมูลช่างตัดผม
        if (!apiSuccess && typeof db !== 'undefined' && db !== null) {
            console.log("Fallback to Client-Side Firebase for fetching barbers...");
            try {
                const snapshot = await db.collection('users')
                    .where('role', '==', 'barber')
                    .where('status', '==', 'active')
                    .get();
                
                if (!snapshot.empty) {
                    barberSelect.innerHTML = '<option value="" disabled selected>-- เลือกช่าง --</option>';
                    snapshot.forEach(doc => {
                        const data = doc.data();
                        const option = document.createElement('option');
                        option.value = doc.id;
                        option.textContent = data.name || doc.id;
                        barberSelect.appendChild(option);
                    });
                } else {
                    barberSelect.innerHTML = '<option value="" disabled selected>-- ไม่มีช่างพร้อมให้บริการ --</option>';
                }
            } catch (error) {
                console.error("Firestore Fetch Error:", error);
                barberSelect.innerHTML = '<option value="" disabled selected>-- โหลดข้อมูลผิดพลาด --</option>';
            }
        } else if (!apiSuccess) {
            barberSelect.innerHTML = '<option value="" disabled selected>-- ระบบขัดข้อง --</option>';
        }

        // 2. ดึงข้อมูลบริการ (แบบเรียลไทม์) เพื่อซิงก์กับการลบโดยแอดมิน
        const serviceSelect = document.getElementById('service');
        if (typeof db !== 'undefined' && db !== null) {
            console.log("Listening to services collection in real-time...");
            unsubscribeServices = db.collection('services')
                .where('status', '==', 'available')
                .onSnapshot(snapshot => {
                    serviceSelect.innerHTML = '<option value="" disabled selected>-- เลือกบริการ --</option>';
                    if (!snapshot.empty) {
                        snapshot.forEach(doc => {
                            const svc = doc.data();
                            const option = document.createElement('option');
                            option.value = `${svc.name}|${svc.price}`;
                            option.textContent = `${svc.name} (${Number(svc.price).toLocaleString()}฿)`;
                            serviceSelect.appendChild(option);
                        });
                    } else {
                        serviceSelect.innerHTML = '<option value="" disabled selected>-- ไม่มีบริการในระบบ --</option>';
                    }
                }, error => {
                    console.error("Firestore Listen Services Error:", error);
                    loadServicesFallback();
                });
        } else {
            loadServicesFallback();
        }

        async function loadServicesFallback() {
            try {
                const res = await fetch('/api/services');
                if (res.ok) {
                    const result = await res.json();
                    if (result.success) {
                        if (result.data.length > 0) {
                            serviceSelect.innerHTML = '<option value="" disabled selected>-- เลือกบริการ --</option>';
                            result.data.forEach(svc => {
                                const option = document.createElement('option');
                                option.value = `${svc.name}|${svc.price}`;
                                option.textContent = `${svc.name} (${Number(svc.price).toLocaleString()}฿)`;
                                serviceSelect.appendChild(option);
                            });
                        } else {
                            serviceSelect.innerHTML = '<option value="" disabled selected>-- ไม่มีบริการในระบบ --</option>';
                        }
                    }
                }
            } catch (error) {
                console.error("Services API Fetch Error:", error);
                serviceSelect.innerHTML = '<option value="" disabled selected>-- ระบบขัดข้อง --</option>';
            }
        }

        // 3. เริ่มติดตามคิววันนี้แบบเรียลไทม์
        initializeQueueListener();

        // 4. ตรวจสอบการแจ้งเตือน Error และความพร้อมใช้งานฐานข้อมูล
        if (typeof db === 'undefined' || db === null) {
            document.getElementById('firebaseErrorBanner').classList.remove('hidden');
        } else {
            // โหลดตั้งค่าร้าน (QR Code) แบบ Real-time
            unsubscribeSettings = db.collection('settings').doc('shop').onSnapshot((doc) => {
                if (doc.exists) {
                    const data = doc.data();
                    const qrContainer = document.getElementById('lineQrContainer');
                    const qrImage = document.getElementById('lineQrImage');
                    
                    if (data.lineQrBase64) {
                        qrImage.src = data.lineQrBase64;
                        qrContainer.classList.remove('hidden');
                    } else {
                        qrContainer.classList.add('hidden');
                    }
                }
            }, (error) => {
                console.error("Error loading shop settings:", error);
            });
        }
    });

    // ป้องกันการรั่วไหลของข้อมูล (Memory Leak Prevention)
    window.addEventListener('beforeunload', () => {
        if (unsubscribeSettings) unsubscribeSettings();
        if (unsubscribeServices) unsubscribeServices();
        if (unsubscribeBookings) unsubscribeBookings();
        if (unsubscribeBarbers) unsubscribeBarbers();
    });
</script>

<%- include('partials/footer') %>
