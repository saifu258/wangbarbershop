<%- include('partials/header') %>

<!-- Error Banner (แสดงเมื่อ Firebase มีปัญหา) -->
<div id="firebaseErrorBanner" class="hidden bg-red-600 text-white text-center py-3 px-4 font-bold shadow-md w-full relative z-[100]">
    <i class="fa-solid fa-triangle-exclamation mr-2 text-xl"></i> 
    ไม่สามารถเชื่อมต่อฐานข้อมูลได้ กรุณาตรวจสอบการตั้งค่า Firebase
</div>

<!-- Hero / Welcome Section -->
<div class="bg-gradient-to-br from-gray-900 via-slate-800 to-gray-900 text-white text-center py-12 px-4 shadow-md relative overflow-hidden">
    <!-- Background pattern decoration -->
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-blue-400 via-zinc-900 to-black"></div>
    <div class="relative z-10 max-w-2xl mx-auto">
        <h1 class="text-4xl sm:text-5xl font-black tracking-wider text-white mb-2 uppercase">WANG BARBER</h1>
        <p class="text-blue-400 font-semibold text-lg sm:text-xl tracking-wide">ร้านตัดผมเเบวัง</p>
        <p class="text-gray-400 text-sm mt-3 max-w-md mx-auto font-light">ยินดีต้อนรับ! บริการตัดผมชายระดับพรีเมียม สไตล์โมเดิร์น บริการอบอุ่นและเป็นกันเอง</p>
    </div>
</div>

<!-- Quick Action Buttons Section -->
<div class="max-w-xl mx-auto mt-6 px-4 flex gap-4">
    <button onclick="scrollToBookingForm()" class="flex-1 bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white font-bold py-3.5 px-6 rounded-2xl shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200 flex justify-center items-center gap-2 text-base">
        <i class="fa-solid fa-calendar-days"></i> จองคิว
    </button>
    <a href="/login" class="flex-1 bg-gray-800 hover:bg-gray-700 active:bg-gray-950 border border-gray-700 text-white font-bold py-3.5 px-6 rounded-2xl shadow-lg hover:shadow-xl text-center transform hover:-translate-y-0.5 transition-all duration-200 flex justify-center items-center gap-2 text-base">
        <i class="fa-solid fa-user-lock"></i> เข้าสู่ระบบพนักงาน
    </a>
</div>

<!-- Queue List Section -->
<div class="max-w-xl mx-auto mt-8 px-4">
    <div class="bg-white shadow-xl rounded-2xl border border-gray-100 p-6 sm:p-8">
        <div class="text-center mb-6">
            <h2 class="text-2xl font-bold text-gray-800 tracking-wide">รายการคิววันนี้</h2>
            <p class="text-gray-500 text-sm mt-1">ตรวจสอบจำนวนคิวและสถานะก่อนทำการจอง</p>
        </div>

        <!-- Summary Cards -->
        <div class="grid grid-cols-3 gap-3 mb-6">
            <!-- waiting count -->
            <div class="bg-amber-50 border border-amber-100 rounded-xl p-3 text-center shadow-sm">
                <p class="text-xs text-amber-600 font-bold mb-1">คิวที่กำลังรอ</p>
                <p id="waitingQueueCount" class="text-2xl font-black text-amber-700">-</p>
            </div>
            <!-- current serving -->
            <div class="bg-purple-50 border border-purple-100 rounded-xl p-3 text-center shadow-sm">
                <p class="text-xs text-purple-600 font-bold mb-1">กำลังให้บริการ</p>
                <p id="servingQueueId" class="text-sm font-black text-purple-700 truncate mt-1">-</p>
            </div>
            <!-- active barbers -->
            <div class="bg-blue-50 border border-blue-100 rounded-xl p-3 text-center shadow-sm">
                <p class="text-xs text-blue-600 font-bold mb-1">ช่างที่เปิดร้าน</p>
                <p id="activeBarbersCount" class="text-2xl font-black text-blue-700">-</p>
            </div>
        </div>

        <!-- Real-time Queue List Container -->
        <div class="space-y-4">
            <div id="queueListContainer" class="space-y-3 max-h-[350px] overflow-y-auto pr-1">
                <!-- Loading state -->
                <div id="queueListLoading" class="text-center py-8 text-gray-500 text-sm">
                    <i class="fa-solid fa-spinner fa-spin text-blue-500 text-2xl mb-2"></i>
                    <p>กำลังโหลดรายการคิว...</p>
                </div>
                <!-- Empty state (hidden by default) -->
                <div id="queueListEmpty" class="hidden text-center py-8 bg-gray-50 rounded-xl border border-dashed border-gray-200 p-6">
                    <i class="fa-solid fa-circle-check text-green-500 text-3xl mb-2"></i>
                    <p class="text-gray-700 font-semibold">ขณะนี้ยังไม่มีคิว</p>
                    <p class="text-gray-500 text-xs mt-1">คุณสามารถจองคิวได้ทันที</p>
                </div>
                <!-- Error state (hidden by default) -->
                <div id="queueListError" class="hidden text-center py-8 p-6 text-red-500 bg-red-50 rounded-xl border border-red-100">
                    <i class="fa-solid fa-triangle-exclamation text-3xl mb-2"></i>
                    <p class="font-medium">ไม่สามารถโหลดรายการคิวได้</p>
                    <button onclick="retryLoadQueues()" class="mt-2 text-xs font-semibold bg-red-100 text-red-700 px-3 py-1.5 rounded-lg hover:bg-red-200 transition-colors">
                        ลองใหม่
                    </button>
                </div>
                <!-- Queue Items -->
                <div id="queueListItems" class="space-y-3"></div>
            </div>
        </div>
    </div>
</div>

<!-- Booking Form Section -->
<div id="bookingFormSection" class="max-w-xl mx-auto mt-8 sm:mt-10 px-4 sm:px-6 mb-12 scroll-mt-20">
    <!-- Card Container -->
