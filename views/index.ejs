            </div>

            <!-- เบอร์โทร -->
            <div class="space-y-1">
                <label for="phone" class="block text-sm font-semibold text-gray-700">เบอร์โทรศัพท์ <span class="text-red-500">*</span></label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fa-solid fa-phone text-gray-400"></i>
                    </div>
                    <input type="tel" id="phone" name="phone" required pattern="[0-9]{9,10}"
                        class="w-full pl-10 px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all bg-gray-50 hover:bg-white focus:bg-white text-gray-800 shadow-sm"
                        placeholder="08X-XXX-XXXX">
