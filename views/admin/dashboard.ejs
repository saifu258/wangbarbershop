<%- include('../partials/header') %>

<!-- HTML2Canvas CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

<style>
    /* Print specific styles */
    @media print {
        body * {
            visibility: hidden;
        }
        #receiptModalOverlay {
            display: block !important;
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: white !important;
        }
        #receiptModalOverlay > div {
            box-shadow: none !important;
            max-width: 100% !important;
            width: 100%;
            border: none !important;
        }
        #receiptArea, #receiptArea * {
            visibility: visible;
        }
        #receiptArea {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            padding: 20px;
        }
        .no-print {
            display: none !important;
        }
    }
</style>

<!-- Auth Overlay -->
<div id="authOverlay" class="fixed inset-0 bg-gray-50 z-[999] flex flex-col items-center justify-center transition-opacity duration-300">
    <i class="fa-solid fa-spinner fa-spin text-4xl text-blue-600 mb-4"></i>
    <p class="text-gray-500 font-medium text-lg">กำลังตรวจสอบสิทธิ์การเข้าถึง...</p>
</div>

<div class="max-w-6xl mx-auto mt-8 sm:mt-10 px-4 sm:px-6 mb-12 flex-grow w-full">
    
    <!-- Top Header -->
    <div class="bg-white rounded-2xl shadow-md border border-gray-100 p-6 mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 relative overflow-hidden">
        <div class="absolute right-0 top-0 h-full w-1/3 bg-gradient-to-l from-blue-50 to-transparent opacity-50 pointer-events-none"></div>
        <div>
            <h2 class="text-2xl sm:text-3xl font-black text-gray-800 flex items-center gap-3">
                <div class="bg-blue-100 text-blue-600 p-2 rounded-xl border border-blue-200">
                    <i class="fa-solid fa-chart-pie"></i>
                </div>
                แดชบอร์ดผู้จัดการ (Admin)
            </h2>
            <p class="text-gray-500 text-sm mt-2 ml-[3.25rem] font-medium">สรุปรายได้และจัดการส่วนแบ่งของวันนี้</p>
        </div>
    </div>

    <!-- Error Banner -->
    <div id="firebaseErrorBanner" class="hidden bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-xl relative mb-6 shadow-sm" role="alert">
        <strong class="font-bold"><i class="fa-solid fa-triangle-exclamation mr-1"></i> แจ้งเตือน:</strong>
        <span class="block sm:inline">ไม่สามารถเชื่อมต่อฐานข้อมูลได้ ระบบกำลังแสดงข้อมูลจำลอง (Mock Data)</span>
    </div>

    <!-- Filter Section (Income Report System) -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5 mb-6 flex flex-col md:flex-row gap-4 items-center justify-between no-print">
        <div class="flex flex-col sm:flex-row gap-4 w-full md:w-auto">
            <div class="flex items-center gap-2">
                <i class="fa-solid fa-calendar-days text-blue-500"></i>
                <select id="filterTime" onchange="applyFilters()" class="px-4 py-2 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none bg-gray-50 text-gray-700 font-semibold w-full sm:w-auto">
                    <option value="daily">สรุปรายวัน (วันนี้)</option>
                    <option value="weekly">สรุปรายสัปดาห์ (สัปดาห์นี้)</option>
                    <option value="monthly">สรุปรายเดือน (เดือนนี้)</option>
                    <option value="all">สรุปทั้งหมด (ตั้งแต่เริ่ม)</option>
                </select>
            </div>
            <div class="flex items-center gap-2">
                <i class="fa-solid fa-user-tie text-blue-500"></i>
                <select id="filterBarber" onchange="applyFilters()" class="px-4 py-2 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none bg-gray-50 text-gray-700 font-semibold w-full sm:w-auto">
                    <option value="all">ช่างตัดผมทั้งหมด</option>
                    <!-- Populated by JS -->
                </select>
            </div>
        </div>
        <button onclick="generateEmployeeReport(event)" class="w-full md:w-auto bg-green-600 hover:bg-green-700 active:bg-green-800 text-white px-5 py-2.5 rounded-xl font-bold shadow-sm transition-all flex items-center justify-center gap-2">
            <i class="fa-solid fa-file-invoice-dollar"></i> ออกใบสรุปรายได้พนักงาน
        </button>
    </div>

    <!-- Part 1: Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <!-- Total Heads -->
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-200 flex items-center gap-6">
            <div class="bg-indigo-100 p-4 rounded-full text-indigo-600 shadow-inner">
                <i class="fa-solid fa-users text-3xl"></i>
            </div>
            <div>
                <p class="text-sm text-gray-500 font-semibold mb-1" id="lblTotalHeads">จำนวนลูกค้าวันนี้</p>
                <h3 class="text-3xl font-black text-gray-800" id="totalHeads">0 <span class="text-lg font-medium text-gray-400">คน</span></h3>
            </div>
        </div>
        <!-- Total Revenue -->
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-200 flex items-center gap-6">
            <div class="bg-green-100 p-4 rounded-full text-green-600 shadow-inner">
                <i class="fa-solid fa-money-bill-wave text-3xl"></i>
            </div>
            <div>
                <p class="text-sm text-gray-500 font-semibold mb-1" id="lblTotalRevenue">รายได้รวมวันนี้ (Gross)</p>
                <h3 class="text-3xl font-black text-gray-800"><span id="totalRevenue">0</span> <span class="text-lg font-medium text-gray-400">บาท</span></h3>
            </div>
        </div>
    </div>

    <!-- Part 2: Split Percentage & Transactions -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 bg-white p-2 sm:p-0 rounded-2xl sm:bg-transparent" id="reportArea">
        
        <!-- Calculator -->
        <div class="lg:col-span-1 bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden h-fit">
            <div class="bg-gray-800 px-5 py-4">
                <h3 class="text-white font-bold"><i class="fa-solid fa-calculator mr-2 text-blue-400"></i> คำนวณส่วนแบ่ง (Split)</h3>
            </div>
            <div class="p-5 space-y-5">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">ส่วนแบ่งช่างตัดผม (%)</label>
                    <input type="number" id="barberPercent" value="60" min="0" max="100" class="w-full px-4 py-2 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">ส่วนแบ่งทางร้าน (%)</label>
                    <input type="number" id="shopPercent" value="40" readonly class="w-full px-4 py-2 border border-gray-200 bg-gray-50 rounded-xl text-gray-500 font-medium outline-none cursor-not-allowed">
                </div>
                
                <hr class="border-gray-100">
                
                <div class="bg-blue-50 p-4 rounded-xl border border-blue-100">
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-sm font-semibold text-blue-800">ส่วนของช่าง:</span>
                        <span class="text-lg font-black text-blue-700" id="barberShare">0 ฿</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm font-semibold text-gray-600">ส่วนของร้าน:</span>
                        <span class="text-lg font-black text-gray-700" id="shopShare">0 ฿</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Transaction List -->
        <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="bg-gray-800 px-5 py-4 flex justify-between items-center rounded-t-2xl">
                <h3 class="text-white font-bold"><i class="fa-solid fa-list-check mr-2 text-blue-400"></i> <span id="lblTransactionTitle">รายการที่เสร็จสิ้นวันนี้</span></h3>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-50 text-gray-600 text-sm tracking-wider border-b border-gray-200">
                            <th class="p-4 font-bold uppercase w-20 text-center">คิว</th>
                            <th class="p-4 font-bold uppercase">ลูกค้า</th>
                            <th class="p-4 font-bold uppercase hidden md:table-cell">บริการ</th>
                            <th class="p-4 font-bold text-right uppercase">ราคา</th>
                            <th class="p-4 font-bold text-center uppercase w-28">จัดการ</th>
                        </tr>
                    </thead>
                    <tbody id="transactionBody" class="divide-y divide-gray-100">
                        <!-- JS renders here -->
                        <tr>
                            <td colspan="5" class="p-8 text-center text-gray-500">
                                <i class="fa-solid fa-spinner fa-spin text-3xl mb-2 text-blue-500"></i><br>
                                กำลังโหลดข้อมูล...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <!-- Part 3: Shop Settings -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden mb-8 mt-6">
        <div class="bg-gray-800 px-5 py-4">
            <h3 class="text-white font-bold"><i class="fa-solid fa-store mr-2 text-blue-400"></i> ตั้งค่าร้านค้า (Shop Settings)</h3>
        </div>
        <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Shop Name -->
                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-gray-700">ชื่อร้าน (Shop Name)</label>
                    <input type="text" id="settingShopName" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all" placeholder="ชื่อร้านของคุณ">
                </div>
                
                <!-- LINE Token -->
                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-gray-700">LINE Messaging API Token (Channel Access Token)</label>
                    <div class="relative">
                        <input type="password" id="settingLineToken" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all pr-10" placeholder="ใส่ Token ของ LINE ที่นี่">
                        <button type="button" onclick="togglePassword('settingLineToken')" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                </div>

                <!-- LINE Channel Secret -->
                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-gray-700">LINE Channel Secret (สำหรับ Webhook)</label>
                    <div class="relative">
                        <input type="password" id="settingLineSecret" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all pr-10" placeholder="ใส่ Channel Secret ของ LINE ที่นี่">
                        <button type="button" onclick="togglePassword('settingLineSecret')" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                </div>

                <!-- Webhook URL Display & Test Button -->
                <div class="space-y-2 md:col-span-2 bg-blue-50 p-4 rounded-xl border border-blue-100">
                    <label class="block text-sm font-semibold text-blue-800">Webhook URL (นำไปใส่ใน LINE Developers)</label>
                    <div class="flex gap-2">
                        <input type="text" id="webhookUrlDisplay" readonly class="w-full px-4 py-2 border border-blue-200 bg-white rounded-lg text-gray-600 text-sm outline-none font-mono" value="กำลังโหลด...">
                        <button type="button" onclick="copyWebhook()" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-bold shadow-sm transition-colors whitespace-nowrap">
                            <i class="fa-regular fa-copy"></i> คัดลอก
                        </button>
                    </div>
                    <div class="mt-3 flex justify-end">
                        <button type="button" onclick="testLineConnection()" id="testLineBtn" class="bg-indigo-100 hover:bg-indigo-200 text-indigo-700 px-4 py-2 rounded-lg text-sm font-bold transition-colors flex items-center gap-2 border border-indigo-300">
                            <i class="fa-solid fa-plug-circle-check"></i> ทดสอบการเชื่อมต่อ (Ping)
                        </button>
                    </div>
                </div>

                <!-- Logo Upload -->
                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-gray-700">โลโก้ร้าน (Logo)</label>
                    <input type="file" id="settingLogoUpload" accept="image/*" class="w-full text-sm text-gray-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition-all cursor-pointer">
                    <div class="mt-3 hidden" id="logoPreviewContainer">
                        <img id="logoPreview" src="" alt="Logo Preview" class="h-16 object-contain border border-gray-200 rounded p-1 bg-gray-50">
                    </div>
                </div>

                <!-- QR Code Upload -->
                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-gray-700">อัปโหลด QR Code LINE (ให้ลูกค้าแอด)</label>
                    <input type="file" id="settingQrUpload" accept="image/*" class="w-full text-sm text-gray-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-green-50 file:text-green-700 hover:file:bg-green-100 transition-all cursor-pointer">
                    <div class="mt-3 hidden" id="qrPreviewContainer">
                        <img id="qrPreview" src="" alt="QR Preview" class="h-24 object-contain border border-gray-200 rounded p-1 bg-gray-50 shadow-sm">
                    </div>
                </div>
            </div>
            <div class="mt-6 flex justify-end">
                <button id="saveSettingsBtn" onclick="saveShopSettings(this)" class="bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white px-6 py-2.5 rounded-xl font-bold shadow-sm transition-all flex items-center gap-2">
                    <i class="fa-solid fa-floppy-disk"></i> บันทึกการตั้งค่า
                </button>
            </div>
        </div>
    </div>

    <!-- Part 4: Employee Management -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden mb-8 mt-6">
        <div class="bg-gray-800 px-5 py-4 flex justify-between items-center">
            <h3 class="text-white font-bold"><i class="fa-solid fa-users-gear mr-2 text-blue-400"></i> จัดการพนักงาน (Employee Management)</h3>
        </div>
        <div class="p-6">
            <!-- Add Employee Button -->
            <div class="mb-6 flex justify-between items-center bg-gray-50 p-5 rounded-xl border border-gray-200">
                <p class="text-gray-600 font-medium">เพิ่มข้อมูลพนักงานใหม่เข้าสู่ระบบ เพื่อจัดการคิวและตั้งค่าต่างๆ</p>
                <button onclick="openAddStaffModal()" class="bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white px-5 py-2.5 rounded-xl font-bold shadow-sm transition-all flex items-center gap-2">
                    <i class="fa-solid fa-user-plus"></i> เพิ่มพนักงานใหม่
                </button>
            </div>

            <!-- Employee List -->
            <h4 class="font-bold text-gray-700 mb-4"><i class="fa-solid fa-users-viewfinder mr-2"></i> รายชื่อพนักงานในระบบ (ช่างตัดผม)</h4>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-50 text-gray-600 text-sm tracking-wider border-b border-gray-200">
                            <th class="p-4 font-bold uppercase">ชื่อ</th>
                            <th class="p-4 font-bold uppercase hidden sm:table-cell">อีเมล</th>
                            <th class="p-4 font-bold text-center uppercase">สถานะรับคิว</th>
                            <th class="p-4 font-bold text-center uppercase w-32">จัดการ</th>
                        </tr>
                    </thead>
                    <tbody id="employeeBody" class="divide-y divide-gray-100">
                        <tr>
                            <td colspan="4" class="p-8 text-center text-gray-500">
                                <i class="fa-solid fa-spinner fa-spin text-3xl mb-2 text-blue-500"></i><br>
                                กำลังโหลดข้อมูลพนักงาน...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Part 5: Services Management -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden mb-8 mt-6">
        <div class="bg-gray-800 px-5 py-4 flex justify-between items-center">
            <h3 class="text-white font-bold"><i class="fa-solid fa-list-check mr-2 text-blue-400"></i> จัดการบริการ (Services Management)</h3>
        </div>
        <div class="p-6">
            <!-- Add Service Form -->
            <div class="bg-gray-50 p-5 rounded-xl border border-gray-200 mb-8">
                <h4 class="font-bold text-gray-700 mb-4"><i class="fa-solid fa-plus mr-2"></i> เพิ่มบริการใหม่</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    <input type="text" id="svcName" placeholder="ชื่อบริการ (เช่น ตัดผมชาย)" class="px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all">
                    <input type="number" id="svcPrice" placeholder="ราคา (บาท)" min="0" class="px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all">
                    <div class="flex justify-end lg:justify-start">
                        <button id="addSvcBtn" onclick="addService()" class="w-full lg:w-auto bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white px-6 py-2.5 rounded-xl font-bold shadow-sm transition-all flex items-center justify-center gap-2">
                            <i class="fa-solid fa-check"></i> บันทึกบริการ
                        </button>
                    </div>
                </div>
            </div>

            <!-- Services List -->
            <h4 class="font-bold text-gray-700 mb-4"><i class="fa-solid fa-list mr-2"></i> รายการบริการในระบบ</h4>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-50 text-gray-600 text-sm tracking-wider border-b border-gray-200">
                            <th class="p-4 font-bold uppercase">ชื่อบริการ</th>
                            <th class="p-4 font-bold text-right uppercase">ราคา (฿)</th>
                            <th class="p-4 font-bold text-center uppercase">สถานะ</th>
                            <th class="p-4 font-bold text-center uppercase w-40">จัดการ</th>
                        </tr>
                    </thead>
                    <tbody id="servicesBody" class="divide-y divide-gray-100">
                        <tr>
                            <td colspan="4" class="p-8 text-center text-gray-500">
                                <i class="fa-solid fa-spinner fa-spin text-3xl mb-2 text-blue-500"></i><br>
                                กำลังโหลดข้อมูลบริการ...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Receipt Modal Overlay -->
<div id="receiptModalOverlay" class="fixed inset-0 bg-black/60 z-[100] hidden flex items-center justify-center p-4 backdrop-blur-sm no-print transition-opacity duration-300">
    <!-- Modal Content -->
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden transform transition-all flex flex-col max-h-[90vh]">
        
        <!-- Header -->
        <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50 no-print">
            <h3 class="font-bold text-gray-800"><i class="fa-solid fa-file-invoice-dollar text-blue-600 mr-2"></i> ใบเสร็จรับเงิน</h3>
            <button onclick="closeReceipt()" class="text-gray-400 hover:text-red-500 transition-colors">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>

        <!-- Receipt Area (This is what gets printed/captured) -->
        <div id="receiptArea" class="p-6 bg-white flex-grow overflow-y-auto font-mono text-black">
            <div class="text-center mb-6">
                <h2 class="text-3xl font-bold tracking-widest border-b-2 border-black pb-2 inline-block">WANG BARBER</h2>
                <p class="text-sm uppercase mt-2">Premium Barbershop</p>
                <p class="text-xs mt-1">Receipt / ใบเสร็จรับเงิน</p>
            </div>
            
            <div class="border-t border-b border-dashed border-black py-4 mb-4 space-y-2 text-sm">
                <div class="flex justify-between">
                    <span>DATE/TIME:</span>
                    <span id="receiptDate" class="font-bold">-</span>
                </div>
                <div class="flex justify-between">
                    <span>QUEUE NO:</span>
                    <span id="receiptQueue" class="font-bold">-</span>
                </div>
                <div class="flex justify-between">
                    <span>BARBER:</span>
                    <span id="receiptBarber" class="font-bold">-</span>
                </div>
                <div class="flex justify-between">
                    <span>CUSTOMER:</span>
                    <span id="receiptCustomer" class="font-bold">-</span>
                </div>
            </div>

            <div class="mb-6">
                <h4 class="text-xs font-bold uppercase tracking-wider mb-2 border-b border-black pb-1">SERVICE</h4>
                <div class="flex justify-between items-center text-sm font-bold mt-2">
                    <span id="receiptService">-</span>
                    <span id="receiptPrice">0 ฿</span>
                </div>
            </div>

            <div class="border-t-2 border-black pt-4 flex justify-between items-center mt-6">
                <span class="font-bold text-lg">TOTAL</span>
                <span id="receiptTotal" class="text-2xl font-bold">0 ฿</span>
            </div>
            
            <div class="text-center mt-10 text-xs border-t border-dashed border-black pt-4">
                <p>THANK YOU</p>
                <p class="mt-1">PLEASE COME AGAIN</p>
                <p class="mt-2 text-[10px]">SYS: WANG-BARBER</p>
            </div>
        </div>

        <!-- Footer Actions -->
