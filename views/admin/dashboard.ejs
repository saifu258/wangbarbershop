    // -----------------------------------------------------
    // บริหารจัดการบริการ (Services Management)
    // -----------------------------------------------------
    async function loadServices() {
        const tbody = document.getElementById('servicesBody');
        let apiSuccess = false;
        
        try {
            const res = await fetch('/api/services?all=true');
            if (res.ok) {
                const result = await res.json();
                if (result.success) {
                    apiSuccess = true;
                    let html = '';
                    if (result.data.length === 0) {
                        html = '<tr><td colspan="4" class="p-8 text-center text-gray-500">ไม่มีบริการในระบบ</td></tr>';
                    } else {
                        result.data.forEach(svc => {
                            const isActive = svc.status !== 'unavailable';
                            html += `
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="p-4 font-semibold text-gray-800 ${!isActive ? 'line-through text-gray-400' : ''}">${svc.name}</td>
                                    <td class="p-4 text-right font-bold text-blue-700 ${!isActive ? 'text-gray-400' : ''}">${Number(svc.price).toLocaleString()}</td>
                                    <td class="p-4 text-center">
                                        <span class="px-3 py-1 rounded-full text-xs font-bold ${isActive ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}">
                                            ${isActive ? 'เปิดให้บริการ' : 'ปิดใช้งาน'}
                                        </span>
                                    </td>
                                    <td class="p-4 text-center space-x-2">
                                        <button onclick="editService('${svc.id}', '${svc.name}', ${svc.price}, '${svc.status}')" class="text-indigo-600 hover:text-indigo-800 px-2 py-1 bg-indigo-50 hover:bg-indigo-100 rounded-lg transition-colors text-sm" title="แก้ไข">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </button>
                                        <button onclick="deleteService('${svc.id}')" class="text-red-600 hover:text-red-800 px-2 py-1 bg-red-50 hover:bg-red-100 rounded-lg transition-colors text-sm" title="ปิดใช้งาน/ลบ">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            `;
                        });
                    }
                    tbody.innerHTML = html;
                }
            }
        } catch (error) {
            console.error("GET /api/services error:", error);
        }

        if (!apiSuccess && typeof db !== 'undefined' && db !== null) {
            console.log("Fallback to Client-Side Firebase for loadServices...");
            try {
                // ดึงข้อมูลบริการจาก Firestore Client SDK
                db.collection('services').onSnapshot(snapshot => {
                    let html = '';
                    if (snapshot.empty) {
                        html = '<tr><td colspan="4" class="p-8 text-center text-gray-500">ไม่มีบริการในระบบ</td></tr>';
                    } else {
                        snapshot.forEach(doc => {
                            const svc = doc.data();
                            const isActive = svc.status !== 'unavailable';
                            html += `
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="p-4 font-semibold text-gray-800 ${!isActive ? 'line-through text-gray-400' : ''}">${svc.name}</td>
                                    <td class="p-4 text-right font-bold text-blue-700 ${!isActive ? 'text-gray-400' : ''}">${Number(svc.price).toLocaleString()}</td>
                                    <td class="p-4 text-center">
                                        <span class="px-3 py-1 rounded-full text-xs font-bold ${isActive ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}">
                                            ${isActive ? 'เปิดให้บริการ' : 'ปิดใช้งาน'}
                                        </span>
                                    </td>
                                    <td class="p-4 text-center space-x-2">
                                        <button onclick="editService('${doc.id}', '${svc.name}', ${svc.price}, '${svc.status}')" class="text-indigo-600 hover:text-indigo-800 px-2 py-1 bg-indigo-50 hover:bg-indigo-100 rounded-lg transition-colors text-sm" title="แก้ไข">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </button>
                                        <button onclick="deleteService('${doc.id}')" class="text-red-600 hover:text-red-800 px-2 py-1 bg-red-50 hover:bg-red-100 rounded-lg transition-colors text-sm" title="ปิดใช้งาน/ลบ">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            `;
                        });
                    }
                    tbody.innerHTML = html;
                }, error => {
                    console.error("Firestore onSnapshot Error:", error);
                    tbody.innerHTML = `<tr><td colspan="4" class="p-8 text-center text-red-500">เกิดข้อผิดพลาดในการโหลดข้อมูล: ${error.message}</td></tr>`;
                });
            } catch (error) {
                console.error("Error setting up snapshot:", error);
                tbody.innerHTML = '<tr><td colspan="4" class="p-8 text-center text-red-500">เกิดข้อผิดพลาดในการตั้งค่า Firestore</td></tr>';
            }
        } else if (!apiSuccess) {
            tbody.innerHTML = '<tr><td colspan="4" class="p-8 text-center text-red-500">ระบบขัดข้อง ไม่สามารถเชื่อมต่อฐานข้อมูลได้</td></tr>';
        }
    }

    async function addService() {
        const name = document.getElementById('svcName').value.trim();
        const price = document.getElementById('svcPrice').value;

        if (!name || !price) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({ icon: 'warning', title: 'ข้อมูลไม่ครบถ้วน', text: 'กรุณากรอกชื่อบริการและราคาให้ครบถ้วน' });
            } else {
                alert("❌ กรุณากรอกชื่อบริการและราคาให้ครบถ้วน");
            }
            return;
        }

        const btn = document.getElementById('addSvcBtn');
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> กำลังบันทึก...';
        btn.disabled = true;

        try {
            // ลองเรียกผ่าน API ของ Backend
            const res = await fetch('/api/services', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, price })
            });

            if (!res.ok) {
                let errorMsg = "API Error";
                try {
                    const errorData = await res.json();
                    errorMsg = errorData.message || errorMsg;
                } catch(e) {}
                
                // Fallback: ใช้ Firebase Client SDK กรณี API พัง (รัน Local ไม่มี serviceAccountKey)
                console.warn("API Failed:", errorMsg, "- falling back to Client SDK");
                if (typeof db !== 'undefined' && db !== null) {
                    await db.collection('services').add({
                        name,
                        price: Number(price),
                        status: 'available',
                        createdAt: firebase.firestore.FieldValue.serverTimestamp()
                    });
                } else {
                    throw new Error("API & DB both failed: " + errorMsg);
                }
            } else {
                const result = await res.json();
                if (!result.success) {
                    throw new Error(result.message || "Unknown API error");
                }
            }

            // ล้างช่องกรอกข้อมูล
            document.getElementById('svcName').value = '';
            document.getElementById('svcPrice').value = '';
            
            // โหลดข้อมูลใหม่เพื่อให้ตารางอัปเดต (กรณีใช้ API)
            loadServices();

            if (typeof Swal !== 'undefined') {
                Swal.fire({ icon: 'success', title: 'เพิ่มบริการสำเร็จ', text: 'บันทึกข้อมูลบริการใหม่เรียบร้อยแล้ว' });
            } else {
                alert("✅ เพิ่มบริการสำเร็จ");
            }
        } catch (error) {
            console.error("Add service error:", error);
            if (typeof Swal !== 'undefined') {
                Swal.fire({ icon: 'error', title: 'เกิดข้อผิดพลาด', text: 'ไม่สามารถเพิ่มบริการได้: ' + error.message });
            } else {
                alert("❌ เกิดข้อผิดพลาดในการเพิ่มบริการ: " + error.message);
            }
        } finally {
            btn.innerHTML = '<i class="fa-solid fa-check"></i> บันทึกบริการ';
            btn.disabled = false;
        }
    }

    async function editService(id, currentName, currentPrice, currentStatus) {
        if (typeof Swal !== 'undefined') {
            const { value: formValues } = await Swal.fire({
                title: 'แก้ไขบริการ',
                html:
                    `<div class="space-y-4 text-left">
                        <div><label class="block text-sm font-bold text-gray-700 mb-1">ชื่อบริการ</label>
                        <input id="swal-input1" class="swal2-input w-full mx-0" value="${currentName}"></div>
                        <div><label class="block text-sm font-bold text-gray-700 mb-1">ราคา</label>
                        <input id="swal-input2" type="number" class="swal2-input w-full mx-0" value="${currentPrice}"></div>
                        <div><label class="block text-sm font-bold text-gray-700 mb-1">สถานะ</label>
                        <select id="swal-input3" class="swal2-select w-full mx-0 px-4 py-2 text-lg border-2 border-gray-300 rounded">
                            <option value="available" ${currentStatus==='available'?'selected':''}>เปิดให้บริการ (Available)</option>
                            <option value="unavailable" ${currentStatus==='unavailable'?'selected':''}>ปิดใช้งาน (Unavailable)</option>
                        </select></div>
                    </div>`,
                focusConfirm: false,
                showCancelButton: true,
                confirmButtonText: 'บันทึก',
                cancelButtonText: 'ยกเลิก',
                preConfirm: () => {
                    const newName = document.getElementById('swal-input1').value;
                    const newPrice = document.getElementById('swal-input2').value;
                    const newStatus = document.getElementById('swal-input3').value;
                    if (!newName || !newPrice) {
                        Swal.showValidationMessage('กรุณากรอกข้อมูลให้ครบถ้วน');
                    }
                    return { name: newName, price: newPrice, status: newStatus };
                }
            });

            if (formValues) {
                updateServiceDB(id, formValues.name, formValues.price, formValues.status);
            }
        } else {
            // Fallback to native prompts
            const newName = prompt("ชื่อบริการ:", currentName);
            if (newName === null) return;
            const newPrice = prompt("ราคา:", currentPrice);
            if (newPrice === null) return;
            
            updateServiceDB(id, newName.trim(), newPrice, currentStatus);
        }
    }

    async function updateServiceDB(id, name, price, status) {
        try {
            const res = await fetch(`/api/services/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, price, status })
            });

            if (!res.ok) {
                if (typeof db !== 'undefined' && db !== null) {
                    await db.collection('services').doc(id).update({
                        name: name,
                        price: Number(price),
                        status: status
                    });
                } else {
                    throw new Error("Update failed");
                }
            }
            if (typeof Swal !== 'undefined') Swal.fire({ icon: 'success', title: 'อัปเดตข้อมูลสำเร็จ', toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 });
        } catch (error) {
            console.error("Update service error:", error);
            alert("❌ แก้ไขข้อมูลไม่สำเร็จ");
        }
    }

    async function deleteService(id) {
        let isConfirm = false;
        if (typeof Swal !== 'undefined') {
            const result = await Swal.fire({
                title: 'ยืนยันการลบ?',
                text: "ต้องการปิดการใช้งานบริการนี้ใช่หรือไม่? (สถานะจะถูกเปลี่ยนเป็น Unavailable)",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'ใช่, ปิดการใช้งาน',
                cancelButtonText: 'ยกเลิก'
            });
            isConfirm = result.isConfirmed;
        } else {
            isConfirm = confirm("ต้องการปิดการใช้งานบริการนี้ใช่หรือไม่?");
        }

        if (isConfirm) {
            try {
                const res = await fetch(`/api/services/${id}`, { method: 'DELETE' });
                if (!res.ok) {
                    if (typeof db !== 'undefined' && db !== null) {
                        await db.collection('services').doc(id).update({ status: 'unavailable' });
                    } else {
                        throw new Error("Delete failed");
                    }
                }
                if (typeof Swal !== 'undefined') Swal.fire({ icon: 'success', title: 'ปิดใช้งานสำเร็จ', toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 });
            } catch (error) {
                console.error("Delete service error:", error);
                alert("❌ ปิดการใช้งานไม่สำเร็จ");
            }
        }
    }
</script>

