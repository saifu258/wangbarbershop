<script>
    let allCompletedBookings = [];
    let filteredBookings = [];

    // Mock Data สำหรับทดสอบเมื่อไม่มี Firebase
    const mockBookings = [
        { id: 'm1', queueId: 'A101', firstName: 'สมชาย', lastName: 'รักดี', serviceName: 'ตัดผม', servicePrice: 200, barber: 'Barber 1', completedAt: new Date() },
        { id: 'm2', queueId: 'A102', firstName: 'วิชัย', lastName: '', serviceName: 'ตัดผม + โกนหนวด', servicePrice: 250, barber: 'Barber 2', completedAt: new Date() },
        { id: 'm3', queueId: 'A103', firstName: 'มาริโอ้', lastName: '', serviceName: 'ตัดผม', servicePrice: 200, barber: 'Barber 1', completedAt: new Date() },
        { id: 'm4', queueId: 'A104', firstName: 'จอห์น', lastName: 'สมิธ', serviceName: 'โกนหนวด', servicePrice: 100, barber: 'Barber 2', completedAt: new Date() }
    ];

    document.addEventListener('DOMContentLoaded', () => {
        // [Route Protection] ดักการเข้าถึงหน้า admin
        if (typeof firebase !== 'undefined' && firebase.auth) {
            firebase.auth().onAuthStateChanged(async (user) => {
                if (!user) {
                    if (!sessionStorage.getItem('loggingOut')) {
                        alert("⚠️ กรุณาเข้าสู่ระบบก่อนเข้าใช้งาน");
                    }
                    sessionStorage.removeItem('loggingOut');
                    window.location.replace('/login');
                } else {
                    try {
                        const response = await fetch('/api/verify-role', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ uid: user.uid, email: user.email })
                        });
                        
                        const result = await response.json();
                        
                        if (!response.ok || !result.success) {
                            alert("❌ ไม่พบข้อมูลสิทธิ์ผู้ใช้งาน หรือเกิดข้อผิดพลาด");
                            window.location.href = '/';
                            return;
                        }

                        if (result.role !== 'manager') {
                            alert("❌ คุณไม่มีสิทธิ์เข้าถึงหน้าแดชบอร์ดผู้จัดการ");
                            window.location.href = '/';
                        } else {
                            // อนุญาตให้เข้าถึง
                            document.getElementById('authOverlay').classList.add('opacity-0');
                            setTimeout(() => document.getElementById('authOverlay').classList.add('hidden'), 300);
                            
                            setupCalculator();
                            loadData();
                            loadShopSettings();
                            loadEmployees();
                            loadServices();
                        }
                    } catch (error) {
                        console.error("Error checking role:", error);
                        alert("❌ เกิดข้อผิดพลาดในการตรวจสอบสิทธิ์");
                        window.location.href = '/';
                    }
                }
            });
        } else {
            // Fallback for no Firebase config
            document.getElementById('authOverlay').classList.add('hidden');
            setupCalculator();
            loadData();
            loadShopSettings();
            loadServices();
        }
    });

    // 1. ตั้งค่าเครื่องคิดเลขส่วนแบ่ง
    function setupCalculator() {
        const barberInput = document.getElementById('barberPercent');
        const shopInput = document.getElementById('shopPercent');
        
        barberInput.addEventListener('input', () => {
            let val = parseInt(barberInput.value) || 0;
            if (val > 100) { val = 100; barberInput.value = 100; }
            if (val < 0) { val = 0; barberInput.value = 0; }
            
            shopInput.value = 100 - val;
            updateShares();
        });
    }

    // 2. ดึงข้อมูลจาก Firebase (แบบ Real-time และทั้งหมด)
    function loadData() {
        if (typeof db !== 'undefined' && db !== null) {
            try {
                // ดึงข้อมูลคิวที่เสร็จแล้วทั้งหมดมาครั้งเดียวแบบ Real-time เพื่อให้ฟิลเตอร์ Client-side ทำงานได้รวดเร็ว
                db.collection("bookings")
                    .where("status", "==", "completed")
                    .onSnapshot(snapshot => {
                        allCompletedBookings = [];
                        snapshot.forEach(doc => {
                            allCompletedBookings.push({ id: doc.id, ...doc.data() });
                        });
                        
                        // Sort by time (latest first)
                        allCompletedBookings.sort((a,b) => {
                            const timeA = a.completedAt?.toDate ? a.completedAt.toDate().getTime() : new Date(a.completedAt || 0).getTime();
                            const timeB = b.completedAt?.toDate ? b.completedAt.toDate().getTime() : new Date(b.completedAt || 0).getTime();
                            return timeB - timeA;
                        });

                        applyFilters(); // กรองและแสดงผลทันที
                    }, error => {
                        console.error("Error listening to bookings:", error);
                        showMockData("เกิดข้อผิดพลาดในการดึงข้อมูลจากฐานข้อมูล");
                    });

            } catch (error) {
                console.error("Error loading data setup:", error);
                showMockData("เกิดข้อผิดพลาดในการตั้งค่าฐานข้อมูล");
            }
        } else {
            showMockData("ไม่ได้ตั้งค่า Firebase Configuration");
        }
    }

    function showMockData(reason) {
        document.getElementById('firebaseErrorBanner').classList.remove('hidden');
        console.warn(reason + " - Using Mock Data");
        allCompletedBookings = mockBookings;
        applyFilters();
    }

    // ระบบกรองรายงาน
    function applyFilters() {
        const timeFilter = document.getElementById('filterTime').value;
        const barberFilter = document.getElementById('filterBarber').value;
        
        const now = new Date();
        let startDate = new Date(0); // Default all time
        let endDate = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 23, 59, 59, 999);
        let timeLabel = "ทั้งหมด";

        if (timeFilter === 'daily') {
            startDate = new Date(now.getFullYear(), now.getMonth(), now.getDate());
            timeLabel = "วันนี้";
        } else if (timeFilter === 'weekly') {
            const day = now.getDay() || 7; // Convert Sun(0) to 7
            startDate = new Date(now.getFullYear(), now.getMonth(), now.getDate());
            startDate.setDate(startDate.getDate() - (day - 1)); // Go back to Monday
            timeLabel = "สัปดาห์นี้";
        } else if (timeFilter === 'monthly') {
            startDate = new Date(now.getFullYear(), now.getMonth(), 1);
            timeLabel = "เดือนนี้";
        }

        // อัปเดตข้อความบน UI
        document.getElementById('lblTotalHeads').innerText = `จำนวนลูกค้า${timeLabel}`;
        document.getElementById('lblTotalRevenue').innerText = `รายได้รวม${timeLabel} (Gross)`;
        document.getElementById('lblTransactionTitle').innerText = `รายการที่เสร็จสิ้น${timeLabel}`;

        filteredBookings = allCompletedBookings.filter(b => {
            const bDate = b.completedAt?.toDate ? b.completedAt.toDate() : new Date(b.completedAt || 0);
            
            // กรองเวลา
            let timeMatch = true;
            if (timeFilter !== 'all') {
                timeMatch = bDate >= startDate && bDate <= endDate;
            }

            // กรองช่าง
            let barberMatch = true;
            if (barberFilter !== 'all') {
                barberMatch = (b.barber === barberFilter);
            }

            return timeMatch && barberMatch;
        });

        renderTransactions();
    }

    let grossRevenue = 0;

    // 3. Render ตารางและคำนวณยอด
    function renderTransactions() {
        const tbody = document.getElementById('transactionBody');
        document.getElementById('totalHeads').innerHTML = `${filteredBookings.length} <span class="text-lg font-medium text-gray-400">คน</span>`;
        
        grossRevenue = 0;
        let html = '';

        if (filteredBookings.length === 0) {
            html = `<tr><td colspan="5" class="p-8 text-center text-gray-500">ยังไม่มีรายการที่เสร็จสิ้นในช่วงเวลานี้</td></tr>`;
        } else {
            filteredBookings.forEach(b => {
                const price = Number(b.servicePrice) || 0;
                grossRevenue += price;
                
                html += `
                    <tr class="hover:bg-blue-50/50 transition-colors group">
                        <td class="p-4 text-center font-bold text-gray-800">
                            <span class="inline-block bg-white text-gray-700 px-3 py-1 rounded-lg border border-gray-200 shadow-sm text-sm">${b.queueId || '-'}</span>
                        </td>
                        <td class="p-4 font-semibold text-gray-700">${b.firstName} ${b.lastName || ''}</td>
                        <td class="p-4 text-gray-500 text-sm hidden md:table-cell">
                            <span class="bg-gray-100 px-2 py-1 rounded-md border border-gray-200">${b.serviceName}</span>
                        </td>
                        <td class="p-4 text-right font-bold text-blue-700">${price.toLocaleString()} ฿</td>
                        <td class="p-4 text-center">
                            <button onclick="openReceipt('${b.id}')" class="bg-white hover:bg-blue-50 text-blue-600 px-3 py-1.5 rounded-lg text-sm font-bold border border-blue-200 shadow-sm hover:shadow transition-all flex items-center gap-1.5 mx-auto">
                                <i class="fa-solid fa-receipt"></i> <span class="hidden sm:inline">ใบเสร็จ</span>
                            </button>
                        </td>
                    </tr>
                `;
            });
        }
        
        tbody.innerHTML = html;
        document.getElementById('totalRevenue').innerText = grossRevenue.toLocaleString();
        updateShares();
    }

    function updateShares() {
        const barberPercent = parseInt(document.getElementById('barberPercent').value) || 0;
        const shopPercent = 100 - barberPercent;
        
        const barberShare = (grossRevenue * barberPercent) / 100;
        const shopShare = (grossRevenue * shopPercent) / 100;
        
        document.getElementById('barberShare').innerText = Math.floor(barberShare).toLocaleString() + ' ฿';
        document.getElementById('shopShare').innerText = Math.floor(shopShare).toLocaleString() + ' ฿';
    }

    // 4. ระบบใบเสร็จรับเงิน (Receipt)
    let currentReceiptBooking = null;

    function openReceipt(id) {
        currentReceiptBooking = filteredBookings.find(b => b.id === id);
        if (!currentReceiptBooking) return;
        
        const b = currentReceiptBooking;
        const dateObj = b.completedAt && b.completedAt.toDate ? b.completedAt.toDate() : new Date(b.completedAt);
        
        document.getElementById('receiptDate').innerText = dateObj.toLocaleDateString('th-TH') + ' ' + dateObj.toLocaleTimeString('th-TH', {hour:'2-digit', minute:'2-digit'});
        document.getElementById('receiptQueue').innerText = b.queueId || '-';
        document.getElementById('receiptBarber').innerText = b.barber || '-';
        document.getElementById('receiptCustomer').innerText = `${b.firstName} ${b.lastName || ''}`;
        document.getElementById('receiptService').innerText = b.serviceName;
        document.getElementById('receiptPrice').innerText = `${Number(b.servicePrice).toLocaleString()} ฿`;
        document.getElementById('receiptTotal').innerText = `${Number(b.servicePrice).toLocaleString()} ฿`;
        
        document.getElementById('receiptModalOverlay').classList.remove('hidden');
    }

    function closeReceipt() {
        document.getElementById('receiptModalOverlay').classList.add('hidden');
    }

    function printReceipt() {
        window.print();
    }

    async function downloadReceiptImage() {
        try {
            const receiptElement = document.getElementById('receiptArea');
            // ซ่อน Scrollbar ชั่วคราว
            receiptElement.style.overflow = 'visible';
            
            const canvas = await html2canvas(receiptElement, {
                scale: 2, // เพิ่มความคมชัด
                backgroundColor: '#ffffff'
            });
            
            receiptElement.style.overflow = 'auto'; // คืนค่า
            
            const image = canvas.toDataURL("image/jpeg", 0.9);
            const link = document.createElement('a');
            link.href = image;
            const q = currentReceiptBooking ? currentReceiptBooking.queueId : 'receipt';
            link.download = `wangbarber_receipt_${q}.jpg`;
            link.click();
        } catch (err) {
            console.error("Error generating image:", err);
            alert("❌ ไม่สามารถสร้างรูปภาพได้");
        }
    }

    // 5. ตั้งค่าร้านค้า (Shop Settings)
    let currentLogoBase64 = '';
    let currentQrBase64 = '';

    // โหลดการตั้งค่า
    async function loadShopSettings() {
        if (typeof db !== 'undefined' && db !== null) {
            try {
                // แก้ไขให้ใช้ onSnapshot หากต้องการให้เปลี่ยนทันที หรือ get() ถ้าดึงแค่ตอนโหลด
                const doc = await db.collection('settings').doc('shop').get();
                if (doc.exists) {
                    const data = doc.data();
                    if (data.shopName) document.getElementById('settingShopName').value = data.shopName;
                    if (data.lineToken) document.getElementById('settingLineToken').value = data.lineToken;
                    if (data.lineSecret) document.getElementById('settingLineSecret').value = data.lineSecret;
                    
                    if (data.logoBase64) {
                        currentLogoBase64 = data.logoBase64;
                        const preview = document.getElementById('logoPreview');
                        preview.src = data.logoBase64;
                        document.getElementById('logoPreviewContainer').classList.remove('hidden');
                    }

                    if (data.lineQrBase64) {
                        currentQrBase64 = data.lineQrBase64;
                        const preview = document.getElementById('qrPreview');
                        preview.src = data.lineQrBase64;
                        document.getElementById('qrPreviewContainer').classList.remove('hidden');
                    }
                }
            } catch (error) {
                console.error("Error loading settings:", error);
            }
        }
    }

    // ฟังก์ชันย่อขนาดภาพ (Client-side Image Resizer)
    function compressImage(file, maxWidth, quality) {
        return new Promise((resolve, reject) => {
            const img = new Image();
            img.src = URL.createObjectURL(file);
            img.onload = () => {
                let width = img.width;
                let height = img.height;

                // ย่อขนาดถ้าเกิน maxWidth
                if (width > maxWidth) {
                    height = Math.round((height * maxWidth) / width);
                    width = maxWidth;
                }

                const canvas = document.createElement('canvas');
                canvas.width = width;
                canvas.height = height;

                const ctx = canvas.getContext('2d');
                // Fill with white background first for transparent images like PNG
                ctx.fillStyle = '#FFFFFF';
                ctx.fillRect(0, 0, width, height);
                ctx.drawImage(img, 0, 0, width, height);

                // แปลงเป็น base64 (ใช้ JPEG เพื่อลดขนาดได้มาก)
                const dataUrl = canvas.toDataURL('image/jpeg', quality);
                resolve(dataUrl);
            };
            img.onerror = (error) => reject(error);
        });
    }

    // Toggle Password Masking
    function togglePassword(inputId) {
        const input = document.getElementById(inputId);
        if (input.type === "password") {
            input.type = "text";
        } else {
            input.type = "password";
        }
    }

    // Generate Webhook URL for Express Server
    function updateWebhookUrlDisplay() {
        const url = window.location.origin + "/api/webhook";
        document.getElementById('webhookUrlDisplay').value = url;
    }
    
    // เรียกใช้ตอนโหลดหน้า
    document.addEventListener('DOMContentLoaded', updateWebhookUrlDisplay);

    function copyWebhook() {
        const copyText = document.getElementById("webhookUrlDisplay");
        copyText.select();
        copyText.setSelectionRange(0, 99999);
        navigator.clipboard.writeText(copyText.value);
        alert("📋 คัดลอก Webhook URL แล้ว!");
    }

    // ทดสอบ Token ก่อนบันทึก
    async function testLineConnection() {
        const token = document.getElementById('settingLineToken').value.trim();
        if (!token) {
            alert("⚠️ กรุณากรอก LINE Token ก่อนทดสอบ");
            return;
        }

        const btn = document.getElementById('testLineBtn');
        const originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> กำลังทดสอบ...';

        try {
            const testUrl = '/api/testLineConnection';
            
            const response = await fetch(testUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ token: token })
            });
            
            const result = await response.json();
            if (response.ok && result.success) {
                alert("✅ การทดสอบเชื่อมต่อ LINE API สำเร็จ!");
            } else {
                alert("❌ การทดสอบล้มเหลว: " + (result.message || "Token ไม่ถูกต้อง"));
            }
        } catch (error) {
            console.error("Test Error:", error);
            alert("❌ ไม่สามารถติดต่อ Server ได้ (อาจจะยังไม่ได้ Deploy Cloud Functions)");
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        }
    }

    // อัปโหลดโลโก้
    document.getElementById('settingLogoUpload').addEventListener('change', async function(e) {
        const file = e.target.files[0];
        if (!file) return;

        try {
            // ย่อขนาดภาพให้กว้างสูงสุด 500px คุณภาพ 70%
            currentLogoBase64 = await compressImage(file, 500, 0.7);
            const preview = document.getElementById('logoPreview');
            preview.src = currentLogoBase64;
            document.getElementById('logoPreviewContainer').classList.remove('hidden');
        } catch (err) {
            console.error(err);
            alert("❌ ไม่สามารถประมวลผลรูปภาพได้");
        }
    });

    // อัปโหลด QR Code
    document.getElementById('settingQrUpload').addEventListener('change', async function(e) {
        const file = e.target.files[0];
        if (!file) return;

        try {
            // ย่อขนาดภาพให้กว้างสูงสุด 500px คุณภาพ 70%
            currentQrBase64 = await compressImage(file, 500, 0.7);
            const preview = document.getElementById('qrPreview');
            preview.src = currentQrBase64;
            document.getElementById('qrPreviewContainer').classList.remove('hidden');
        } catch (err) {
            console.error(err);
            alert("❌ ไม่สามารถประมวลผลรูปรหัส QR ได้");
        }
    });

    // บันทึกการตั้งค่า
    async function saveShopSettings(btn) {
        const shopName = document.getElementById('settingShopName').value.trim();
        const lineToken = document.getElementById('settingLineToken').value.trim();

        // [Validation] ตรวจสอบขนาดข้อมูลก่อนบันทึก
        // Base64 1 ตัวอักษร = 1 Byte. เราตั้ง Limit ไว้ที่ไม่เกิน ~800KB เพื่อความปลอดภัยของ Firestore (Max 1MB)
        const maxSafeSize = 800000; 
        const payloadSize = (currentLogoBase64?.length || 0) + (currentQrBase64?.length || 0);
        
        if (payloadSize > maxSafeSize) {
            alert('❌ รูปภาพใหญ่เกินไป กรุณาเลือกรูปอื่นที่มีขนาดเล็กลง (แม้จะย่อแล้วแต่ไฟล์ก็ยังใหญ่เกิน)');
            return;
        }

        const originalText = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> กำลังบันทึก...';
        btn.classList.add('opacity-70', 'cursor-not-allowed');

        if (typeof db !== 'undefined' && db !== null) {
            try {
                const data = {
                    shopName: shopName,
                    lineToken: lineToken,
                    lineSecret: document.getElementById('settingLineSecret').value.trim(),
                    logoBase64: currentLogoBase64,
                    lineQrBase64: currentQrBase64,
                    updatedAt: firebase.firestore.FieldValue.serverTimestamp()
                };
                
                await db.collection('settings').doc('shop').set(data, { merge: true });
                alert("✅ บันทึกการตั้งค่าสำเร็จ!");
            } catch (error) {
                console.error("Error saving settings:", error);
                alert("❌ เกิดข้อผิดพลาดในการบันทึกการตั้งค่า: " + error.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
                btn.classList.remove('opacity-70', 'cursor-not-allowed');
            }
        } else {
            alert("✅ (โหมดจำลอง) บันทึกการตั้งค่าสำเร็จ!\n" + JSON.stringify({shopName, lineToken: lineToken ? "***" : ""}));
            btn.disabled = false;
            btn.innerHTML = originalText;
            btn.classList.remove('opacity-70', 'cursor-not-allowed');
        }
    }

    // 6. ระบบจัดการพนักงาน (Employee Management)
    function loadEmployees() {
        if (typeof db !== 'undefined' && db !== null) {
            // ดึงเฉพาะ role = barber เพื่อมาแสดงในตาราง (สามารถเปลี่ยนดึงทั้งหมดได้)
            db.collection('users').where('role', '==', 'barber').onSnapshot(snapshot => {
                const tbody = document.getElementById('employeeBody');
                if (snapshot.empty) {
                    tbody.innerHTML = `<tr><td colspan="4" class="p-8 text-center text-gray-500">ไม่มีข้อมูลพนักงานช่างตัดผม</td></tr>`;
                    return;
                }
                
                let html = '';
                snapshot.forEach(doc => {
                    const emp = { email: doc.id, ...doc.data() };
                    const isAvailable = emp.status === 'available';
                    
                    html += `
                        <tr class="hover:bg-blue-50/50 transition-colors group">
                            <td class="p-4 font-bold text-gray-800">${emp.name || '-'}</td>
                            <td class="p-4 text-gray-500 text-sm hidden sm:table-cell">${emp.email}</td>
                            <td class="p-4 text-center">
                                <span class="px-3 py-1 rounded-full text-xs font-bold ${isAvailable ? 'bg-green-100 text-green-700 border border-green-200' : 'bg-red-100 text-red-700 border border-red-200'}">
                                    ${isAvailable ? '<i class="fa-solid fa-circle-check"></i> ว่างรับคิว' : '<i class="fa-solid fa-circle-xmark"></i> ติดธุระ'}
                                </span>
                            </td>
                            <td class="p-4 text-center flex justify-center gap-2">
                                <button onclick="toggleEmployeeStatus('${emp.email}', '${emp.status}')" class="${isAvailable ? 'bg-red-50 text-red-600 hover:bg-red-100 border-red-200' : 'bg-green-50 text-green-600 hover:bg-green-100 border-green-200'} px-3 py-1.5 rounded-lg text-sm font-bold border transition-colors shadow-sm" title="${isAvailable ? 'เปลี่ยนสถานะเป็น ไม่ว่าง' : 'เปลี่ยนสถานะเป็น ว่าง'}">
                                    <i class="fa-solid fa-toggle-${isAvailable ? 'off' : 'on'}"></i>
                                </button>
                                <button onclick="deleteEmployee('${emp.email}')" class="bg-white text-gray-400 hover:bg-red-50 hover:text-red-600 px-3 py-1.5 rounded-lg text-sm font-bold border border-gray-200 hover:border-red-200 transition-colors shadow-sm" title="ลบข้อมูลพนักงาน">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                });
                tbody.innerHTML = html;
                
                // Populating Filter Dropdown
                const barberSelect = document.getElementById('filterBarber');
                const selectedBarber = barberSelect.value;
                barberSelect.innerHTML = '<option value="all">ช่างตัดผมทั้งหมด</option>';
                
                snapshot.forEach(doc => {
                    const emp = doc.data();
                    if(emp.name) {
                        const option = document.createElement('option');
                        option.value = emp.name;
                        option.textContent = emp.name;
                        if(emp.name === selectedBarber) option.selected = true;
                        barberSelect.appendChild(option);
                    }
                });
                
                applyFilters(); // Re-apply in case filter name was removed
            });
        }
    }

    function showToast(message, type = 'success') {
        const toast = document.getElementById('toastNotification');
        const icon = document.getElementById('toastIcon');
        const text = document.getElementById('toastMessage');

        text.innerText = message;
        
        toast.className = 'fixed top-5 right-5 z-[60] flex items-center p-4 mb-4 text-gray-700 bg-white rounded-xl shadow-xl border-l-4 transform transition-all duration-300 translate-x-0 opacity-100';
        icon.className = 'inline-flex items-center justify-center flex-shrink-0 w-8 h-8 rounded-lg text-white';

        if (type === 'success') {
            toast.classList.add('border-green-500');
            icon.classList.add('bg-green-500');
            icon.innerHTML = '<i class="fa-solid fa-check"></i>';
        } else {
            toast.classList.add('border-red-500');
            icon.classList.add('bg-red-500');
            icon.innerHTML = '<i class="fa-solid fa-xmark"></i>';
        }

        // Auto hide after 3 seconds
        setTimeout(() => {
            hideToast();
        }, 3000);
    }

    function hideToast() {
        const toast = document.getElementById('toastNotification');
        toast.classList.remove('translate-x-0', 'opacity-100');
        toast.classList.add('translate-x-full', 'opacity-0');
    }

    function openAddStaffModal() {
        document.getElementById('modalEmpName').value = '';
        document.getElementById('modalEmpEmail').value = '';
        document.getElementById('modalEmpPassword').value = '';
        document.getElementById('modalEmpRole').value = 'barber';
        document.getElementById('addStaffModal').classList.remove('hidden');
    }

    function closeAddStaffModal() {
        document.getElementById('addStaffModal').classList.add('hidden');
    }

    async function submitAddStaff() {
        const name = document.getElementById('modalEmpName').value.trim();
        const email = document.getElementById('modalEmpEmail').value.trim();
        const password = document.getElementById('modalEmpPassword').value.trim();
        const role = document.getElementById('modalEmpRole').value;

        if (!name || !email || !password) {
            showToast('กรุณากรอกข้อมูลให้ครบถ้วน', 'error');
            return;
        }

        if (password.length < 6) {
            showToast('รหัสผ่านต้องมีอย่างน้อย 6 ตัวอักษร', 'error');
            return;
        }

        const btn = document.getElementById('modalAddEmpBtn');
        const originalText = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Checking...';
        btn.classList.add('opacity-70', 'cursor-not-allowed');

        try {
            // สร้าง Secondary Firebase App เพื่อหลีกเลี่ยงการถูก Logout ออกจากบัญชี Admin หลัก
            const secondaryApp = firebase.initializeApp(firebaseConfig, "SecondaryApp");
            const newAuth = secondaryApp.auth();

            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';

            // สร้างบัญชีใหม่ใน Firebase Authentication
            const userCredential = await newAuth.createUserWithEmailAndPassword(email, password);
            const newUser = userCredential.user;
            
            await newAuth.signOut(); // ออกจากระบบในแอปจำลอง
            secondaryApp.delete(); // ลบแอปจำลองทิ้งเพื่อคืนหน่วยความจำ

            // Save new staff member into Firestore using UID
            await db.collection('users').doc(newUser.uid).set({
                name: name,
                email: email,
                role: role,
                status: 'available',
                createdAt: firebase.firestore.FieldValue.serverTimestamp()
            });

            showToast('✅ Staff added successfully', 'success');
            closeAddStaffModal();
            loadEmployees(); // Refresh the list
        } catch (error) {
            console.error("Error adding staff:", error);
            if (error.code === 'auth/email-already-in-use') {
                showToast('อีเมลนี้มีในระบบแล้ว กรุณาใช้อีเมลอื่น', 'error');
            } else {
                showToast("เกิดข้อผิดพลาด: " + error.message, 'error');
            }
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalText;
            btn.classList.remove('opacity-70', 'cursor-not-allowed');
        }
    }

    async function toggleEmployeeStatus(email, currentStatus) {
        if (!confirm(`ยืนยันการเปลี่ยนสถานะของ ${email} หรือไม่?`)) return;
        try {
            const newStatus = currentStatus === 'available' ? 'busy' : 'available';
            await db.collection('users').doc(email).update({ status: newStatus });
        } catch (error) {
            console.error("Error updating status:", error);
            alert("❌ เกิดข้อผิดพลาดในการเปลี่ยนสถานะ: " + error.message);
        }
    }

    async function deleteEmployee(email) {
        if (!confirm(`⚠️ ยืนยันการลบสิทธิ์ของ ${email} หรือไม่?\n\n(หมายเหตุ: การลบนี้จะตัดสิทธิ์การเข้าระบบทันที แต่ข้อมูลใน Auth ต้องไปลบในหน้า Firebase Console)`)) return;
        try {
            await db.collection('users').doc(email).delete();
            alert(`✅ ลบข้อมูลพนักงาน ${email} สำเร็จ`);
        } catch (error) {
            console.error("Error deleting employee:", error);
            alert("❌ เกิดข้อผิดพลาดในการลบพนักงาน: " + error.message);
        }
    }

    // 7. ออกใบสรุปรายได้พนักงาน (Employee Payslip)
    function generateEmployeeReport(event) {
        const barberFilter = document.getElementById('filterBarber').value;
        if (barberFilter === 'all') {
            alert("⚠️ กรุณาเลือก 'ช่างตัดผม' ที่ต้องการออกใบสรุปรายได้ ก่อนคลิกปุ่มนี้");
            return;
        }

        const timeFilter = document.getElementById('filterTime').value;
        const timeFilterText = document.getElementById('filterTime').options[document.getElementById('filterTime').selectedIndex].text;
        
        const barberPercent = parseInt(document.getElementById('barberPercent').value) || 0;
        
        // Populate Header Data
        const shopName = document.getElementById('settingShopName')?.value || "WANG BARBER";
        document.getElementById('reportShopName').innerText = shopName;
        document.getElementById('reportEmpName').innerText = barberFilter;
        document.getElementById('reportTimeRange').innerText = timeFilterText;
        
        const now = new Date();
        document.getElementById('reportGeneratedDate').innerText = now.toLocaleDateString('th-TH') + ' ' + now.toLocaleTimeString('th-TH', {hour:'2-digit', minute:'2-digit'});
        document.getElementById('reportSysGen').innerText = now.getTime();
        document.getElementById('reportEmpPercent').innerText = barberPercent + '%';

        // Render Table Data
        const tbody = document.getElementById('reportTransactionBody');
        let html = '';
        let totalJobs = 0;
        let totalGross = 0;
        let totalNet = 0;

        if (filteredBookings.length === 0) {
            html = `<tr><td colspan="5" class="p-8 text-center text-gray-500">ไม่มีรายการที่เสร็จสิ้นในช่วงเวลานี้</td></tr>`;
        } else {
            filteredBookings.forEach(b => {
                const bDate = b.completedAt?.toDate ? b.completedAt.toDate() : new Date(b.completedAt || 0);
                const dateStr = bDate.toLocaleDateString('th-TH', {day:'2-digit', month:'short'}) + ' ' + bDate.toLocaleTimeString('th-TH', {hour:'2-digit', minute:'2-digit'});
                
                const price = Number(b.servicePrice) || 0;
                const commission = Math.floor((price * barberPercent) / 100);
                
                totalGross += price;
                totalNet += commission;
                totalJobs++;
                
                html += `
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="p-3 text-gray-600">${dateStr}</td>
                        <td class="p-3 font-semibold text-gray-800">${b.firstName} ${b.lastName || ''}</td>
                        <td class="p-3 text-gray-500 hidden sm:table-cell">${b.serviceName}</td>
                        <td class="p-3 text-right font-medium text-gray-800">${price.toLocaleString()}</td>
                        <td class="p-3 text-right font-bold text-blue-700">${commission.toLocaleString()}</td>
                    </tr>
                `;
            });
        }
        
        tbody.innerHTML = html;
        document.getElementById('reportTotalJobs').innerText = totalJobs.toLocaleString() + ' งาน';
        document.getElementById('reportTotalGross').innerText = totalGross.toLocaleString() + ' ฿';
        document.getElementById('reportTotalNet').innerText = totalNet.toLocaleString() + ' ฿';

        // Show Modal
        document.getElementById('employeeReportModalOverlay').classList.remove('hidden');
    }

    function closeEmployeeReport() {
        document.getElementById('employeeReportModalOverlay').classList.add('hidden');
    }

