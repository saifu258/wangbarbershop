<%- include('partials/header') %>

    <div class="max-w-md mx-auto mt-16 sm:mt-24 px-4 sm:px-6 mb-24 flex-grow w-full">
        <div class="bg-white shadow-2xl rounded-2xl overflow-hidden border border-gray-100 relative">
            <!-- Decoration -->
            <div class="absolute top-0 right-0 -mt-4 -mr-4 w-24 h-24 bg-gray-500 rounded-full opacity-10 blur-xl"></div>
            <div class="absolute bottom-0 left-0 -mb-4 -ml-4 w-24 h-24 bg-gray-500 rounded-full opacity-10 blur-xl">
            </div>

            <!-- Header -->
            <div class="bg-gray-800 px-6 py-6 text-center relative z-10 shadow-sm">
                <div class="inline-block bg-white/10 p-3 rounded-full mb-3 backdrop-blur-sm border border-gray-700">
                    <i class="fa-solid fa-user-lock text-3xl text-white"></i>
                </div>
                <h2 class="text-3xl font-bold text-white tracking-wide">เข้าสู่ระบบพนักงาน</h2>
                <p class="text-gray-400 text-sm mt-2 font-light">กรุณาเข้าสู่ระบบเพื่อจัดการคิว</p>
            </div>

            <!-- Form -->
            <form id="loginForm" class="p-6 sm:p-8 space-y-6 relative z-10 bg-white">
                <div class="space-y-1">
                    <label for="email" class="block text-sm font-semibold text-gray-700">อีเมลพนักงาน <span
                            class="text-red-500">*</span></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-envelope text-gray-400"></i>
                        </div>
                        <input type="email" id="email" required
                            class="w-full pl-10 px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-gray-800 focus:border-gray-800 outline-none transition-all bg-gray-50 hover:bg-white focus:bg-white text-gray-800 shadow-sm"
                            placeholder="admin@wangbarber.com">
                    </div>
                </div>

                <div class="space-y-1">
                    <label for="password" class="block text-sm font-semibold text-gray-700">รหัสผ่าน <span
                            class="text-red-500">*</span></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-key text-gray-400"></i>
                        </div>
                        <input type="password" id="password" required
                            class="w-full pl-10 px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-gray-800 focus:border-gray-800 outline-none transition-all bg-gray-50 hover:bg-white focus:bg-white text-gray-800 shadow-sm"
                            placeholder="••••••••">
                    </div>
                </div>

                <div class="pt-4">
                    <button type="submit"
                        class="w-full bg-gray-800 hover:bg-gray-900 active:bg-black text-white font-bold py-3.5 px-4 rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200 flex justify-center items-center gap-2">
                        <i class="fa-solid fa-arrow-right-to-bracket"></i> เข้าสู่ระบบ (Login)
                    </button>
                </div>

                <div class="text-center mt-4">
                    <a href="/" class="text-sm text-gray-500 hover:text-gray-800 underline transition-colors"><i
                            class="fa-solid fa-arrow-left mr-1"></i> กลับไปหน้าหลัก (หน้าจองคิว)</a>
                </div>
            </form>
        </div>
    </div>

    <script>
        document.getElementById('loginForm').addEventListener('submit', async function (e) {
            e.preventDefault();

            const email = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value.trim();
            const submitBtn = document.querySelector('button[type="submit"]');
            const originalBtnText = submitBtn.innerHTML;

            if (email && password && typeof firebase !== 'undefined' && firebase.auth) {
                // Loading State
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> กำลังเข้าสู่ระบบ...';
                submitBtn.classList.add('opacity-70', 'cursor-not-allowed');

                try {
                    // 1. เข้าสู่ระบบด้วย Firebase Auth
                    const userCredential = await firebase.auth().signInWithEmailAndPassword(email, password);
                    const user = userCredential.user;

                    console.log("Firebase User Loaded");
                    console.log("Checking Admin Email");

                    // [Bypass for Admin]
                    if (user.email === 'admin@wangbarbershop.com') {
                        console.log("Redirect Admin (Bypass)");
                        window.location.href = '/admin';
                        return;
                    }

                    console.log("Loading User Document");
                    // 2. เรียกใช้ API ฝั่ง Backend เพื่อตรวจสอบและตั้งค่าสิทธิ์ (ลดปัญหาสิทธิ์ฝั่ง Frontend)
                    const response = await fetch('/api/verify-role', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ uid: user.uid, email: user.email })
                    });
                    
                    const result = await response.json();

                    // 3. ตรวจสอบสถานะการตอบกลับ
                    if (!response.ok || !result.success) {
                        await firebase.auth().signOut();
                        console.log("Permission Denied");
                        alert(result.message || 'เกิดข้อผิดพลาด: ไม่สามารถตรวจสอบสิทธิ์ได้');
                        return;
                    }

                    // 4. ตรวจสอบ Role เพื่อพิจารณาการ Redirect
                    if (result.role === 'manager') {
                        console.log("User Document Found");
                        console.log("Redirect Admin");
                        // หากมีสิทธิ์เป็น manager ให้นำทางไปยัง /admin
                        window.location.href = '/admin';
                    } else if (result.role === 'barber') {
                        console.log("User Document Found");
                        console.log("Redirect Barber");
                        // หากมีสิทธิ์เป็นช่างตัดผม ให้นำทางไปยัง /barber
                        window.location.href = '/barber';
                    } else {
                        console.log("Permission Denied");
                        // หากไม่มีสิทธิ์
                        await firebase.auth().signOut();
                        alert('ไม่มีสิทธิ์เข้าใช้งานระบบ กรุณาติดต่อผู้ดูแลระบบ');
                        return;
                    }

                } catch (error) {
                    console.error("Login Error:", error);
                    console.log("Permission Denied (Error)");
                    // รหัส Error ของ Firebase สำหรับ Invalid Credential / User Not Found
                    if (error.code === 'auth/user-not-found' || error.code === 'auth/invalid-credential' || error.code === 'auth/invalid-login-credentials') {
                         alert('อีเมลหรือรหัสผ่านไม่ถูกต้อง หรือไม่มีสิทธิ์เข้าใช้งานระบบ กรุณาติดต่อผู้ดูแลระบบ');
                    } else {
                        alert('Login Error: ' + error.message);
                    }
                } finally {
                    // คืนค่าปุ่ม
                    console.log("Loading Finished");
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalBtnText;
                    submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
                }
            } else if (!firebase || !firebase.auth) {
                alert("⚠️ ระบบ Firebase Auth ยังไม่พร้อมใช้งาน");
            }
        });
    </script>

    <%- include('partials/footer') %>