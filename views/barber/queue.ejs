<%- include('../partials/header') %>

<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- Error Banner (แสดงเมื่อ Firebase มีปัญหา) -->
<div id="firebaseErrorBanner" class="hidden bg-red-600 text-white text-center py-3 px-4 font-bold shadow-md w-full relative z-[100]">
    <i class="fa-solid fa-triangle-exclamation mr-2 text-xl"></i> 
    ไม่สามารถเชื่อมต่อฐานข้อมูลได้ (รันในโหมดจำลอง)
</div>

<!-- Auth Overlay -->
<div id="authOverlay" class="fixed inset-0 bg-gray-50 z-[999] flex flex-col items-center justify-center transition-opacity duration-300">
    <i class="fa-solid fa-spinner fa-spin text-4xl text-blue-600 mb-4"></i>
    <p class="text-gray-500 font-medium text-lg">กำลังตรวจสอบสิทธิ์การเข้าถึง...</p>
</div>

<div class="max-w-6xl mx-auto mt-8 sm:mt-10 px-4 sm:px-6 mb-12 flex-grow w-full">
    
    <!-- Top Dashboard Header -->
    <div class="bg-white rounded-2xl shadow-md border border-gray-100 p-6 mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 relative overflow-hidden">
        
        <!-- Decoration -->
        <div class="absolute right-0 top-0 h-full w-1/3 bg-gradient-to-l from-blue-50 to-transparent opacity-50 pointer-events-none"></div>

        <div>
            <h2 class="text-2xl sm:text-3xl font-black text-gray-800 flex items-center gap-3">
                <div class="bg-blue-100 text-blue-600 p-2 rounded-xl border border-blue-200">
                    <i class="fa-solid fa-clipboard-list"></i>
                </div>
                จัดการคิว (Dashboard)
            </h2>
            <p class="text-gray-500 text-sm mt-2 ml-[3.25rem] font-medium">ดูและจัดการสถานะคิวของลูกค้าในร้านแบบเรียลไทม์</p>
        </div>
        
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 w-full sm:w-auto relative z-10">
            <!-- ปุ่มหน้าจอทีวี -->
            <a href="/tv" target="_blank" title="เปิดหน้าจอแสดงคิวสำหรับลูกค้า" class="bg-slate-700 hover:bg-slate-800 active:bg-slate-900 text-white border border-slate-600 px-4 py-2.5 rounded-xl font-bold text-sm transition-all flex items-center justify-center gap-2 shadow-sm whitespace-nowrap group">
                <i class="fa-solid fa-tv text-blue-300 group-hover:text-blue-200 transition-colors"></i> 
                <span class="hidden sm:inline">ดูหน้าจอทีวี</span>
                <span class="sm:hidden">จอทีวี</span>
            </a>

            <!-- เลือกช่างประจำเครื่องนี้ -->
            <div class="flex items-center gap-2 bg-gray-50 px-4 py-2.5 rounded-xl border border-gray-200 shadow-sm">
                <label for="currentBarberSelect" class="text-sm font-semibold text-gray-700 whitespace-nowrap"><i class="fa-solid fa-scissors text-gray-400 mr-1"></i> พนักงาน:</label>
                <select id="currentBarberSelect" class="bg-transparent border-none outline-none text-blue-600 font-bold cursor-pointer text-sm w-full sm:w-auto">
                    <option value="Barber 1">ช่างคนที่ 1 (Barber 1)</option>
                    <option value="Barber 2">ช่างคนที่ 2 (Barber 2)</option>
                </select>
            </div>
            
            <!-- สวิตช์สถานะว่าง/ไม่ว่าง -->
            <button id="statusToggleBtn" class="bg-green-100 text-green-700 border border-green-300 hover:bg-green-200 active:bg-green-300 px-5 py-2.5 rounded-xl font-bold text-sm transition-all flex items-center justify-center gap-2 shadow-sm whitespace-nowrap">
                <i class="fa-solid fa-circle-check text-lg"></i> <span id="statusText">พร้อมรับคิว</span>
            </button>
        </div>
    </div>

    <!-- Two-column Layout for Tables -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        
        <!-- ฝั่งซ้าย: Queue Table Container (Pending) -->
        <div class="bg-white shadow-xl rounded-2xl overflow-hidden border border-gray-200 flex flex-col h-full">
            <!-- Table Header (Visual Header) -->
            <div class="bg-gray-800 px-6 py-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
                <h3 class="text-white font-bold text-lg"><i class="fa-solid fa-list-ol mr-2 text-blue-400"></i> รายการคิวที่รอ (Pending)</h3>
                <div class="flex items-center gap-3">
                    <button onclick="createTestQueue()" class="bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white text-sm font-bold px-4 py-1.5 rounded-lg shadow-sm transition-all flex items-center gap-2">
                        <i class="fa-solid fa-plus"></i> สร้างคิว
                    </button>
                    <span class="bg-gray-700 text-gray-200 text-xs font-bold px-3 py-1 rounded-full border border-gray-600" id="queueCount">0 คิว</span>
                </div>
            </div>

            <div class="overflow-x-auto flex-grow">
                <table class="w-full text-left border-collapse min-w-[500px]">
                    <thead>
                        <tr class="bg-gray-50 text-gray-600 text-sm tracking-wider border-b border-gray-200">
                            <th class="p-4 font-bold text-center w-20 uppercase">คิว</th>
                            <th class="p-4 font-bold uppercase">ลูกค้า</th>
                            <th class="p-4 font-bold uppercase">บริการ</th>
                            <th class="p-4 font-bold text-center uppercase">เวลา</th>
                            <th class="p-4 font-bold text-center w-28 uppercase">จัดการ</th>
                        </tr>
                    </thead>
                    <tbody id="queueTableBody" class="divide-y divide-gray-100 bg-white">
                        <!-- Data will be injected here via JS -->
                        <tr>
                            <td colspan="5" class="p-12 text-center text-gray-500">
                                <i class="fa-solid fa-spinner fa-spin text-4xl mb-4 text-blue-500"></i><br>
                                <span class="font-medium">กำลังเชื่อมต่อฐานข้อมูล...</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ฝั่งขวา: Serving Queue Container -->
        <div class="bg-white shadow-xl rounded-2xl overflow-hidden border border-blue-200 flex flex-col h-full">
            <div class="bg-blue-600 px-6 py-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
                <h3 class="text-white font-bold text-lg"><i class="fa-solid fa-scissors mr-2 text-blue-200"></i> กำลังให้บริการ (Serving)</h3>
                <span class="bg-blue-800 text-blue-100 text-xs font-bold px-3 py-1 rounded-full" id="servingCount">0 คิว</span>
            </div>
            <div class="overflow-x-auto flex-grow">
                <table class="w-full text-left border-collapse min-w-[500px]">
                    <thead>
                        <tr class="bg-blue-50 text-blue-800 text-sm tracking-wider border-b border-blue-100">
                            <th class="p-4 font-bold text-center w-20 uppercase">คิว</th>
                            <th class="p-4 font-bold uppercase">ลูกค้า</th>
                            <th class="p-4 font-bold uppercase">บริการ</th>
                            <th class="p-4 font-bold text-center uppercase">ช่าง</th>
                            <th class="p-4 font-bold text-center w-28 uppercase">จัดการ</th>
                        </tr>
                    </thead>
                    <tbody id="servingTableBody" class="divide-y divide-blue-50 bg-white">
                        <tr>
                            <td colspan="5" class="p-8 text-center text-gray-500 font-medium">
                                ยังไม่มีคิวที่กำลังให้บริการ
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
        
    </div>
</div>

<script>
    // 0. Route Protection
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof firebase !== 'undefined' && firebase.auth) {
            firebase.auth().onAuthStateChanged(async (user) => {
                if (!user) {
                    if (!sessionStorage.getItem('loggingOut')) {
                        alert("⚠️ กรุณาเข้าสู่ระบบก่อนเข้าใช้งาน");
                    }
                    sessionStorage.removeItem('loggingOut');
                    window.location.replace('/login');
                } else {
                    try {
                        const userDoc = await db.collection('users').doc(user.email).get();
                        if (userDoc.exists) {
                            const role = userDoc.data().role;
                            if (role !== 'barber' && role !== 'manager') {
                                alert("❌ คุณไม่มีสิทธิ์เข้าถึงหน้าจัดการคิวช่าง");
                                window.location.href = '/';
                            } else {
                                // ผ่าน
                                document.getElementById('authOverlay').classList.add('opacity-0');
                                setTimeout(() => document.getElementById('authOverlay').classList.add('hidden'), 300);
                            }
                        } else {
                            alert("❌ ไม่พบข้อมูลสิทธิ์ผู้ใช้งาน");
                            window.location.href = '/';
                        }
                    } catch (err) {
                        console.error("Auth check error:", err);
                        alert("❌ เกิดข้อผิดพลาดในการตรวจสอบสิทธิ์");
                        window.location.href = '/';
                    }
                }
            });
        } else {
            // โหมด Mock
            document.getElementById('authOverlay').classList.add('hidden');
        }
    });

    // 1. สวิตช์สถานะ (UI ล้วนๆ ไว้ต่อยอด)
    let isAvailable = true;
    const statusBtn = document.getElementById('statusToggleBtn');
    const statusText = document.getElementById('statusText');
    
    statusBtn.addEventListener('click', () => {
        isAvailable = !isAvailable;
        if (isAvailable) {
            statusBtn.className = 'bg-green-100 text-green-700 border border-green-300 hover:bg-green-200 active:bg-green-300 px-5 py-2.5 rounded-xl font-bold text-sm transition-all flex items-center justify-center gap-2 shadow-sm whitespace-nowrap';
            statusBtn.innerHTML = '<i class="fa-solid fa-circle-check text-lg"></i> <span id="statusText">พร้อมรับคิว</span>';
        } else {
            statusBtn.className = 'bg-red-100 text-red-700 border border-red-300 hover:bg-red-200 active:bg-red-300 px-5 py-2.5 rounded-xl font-bold text-sm transition-all flex items-center justify-center gap-2 shadow-sm whitespace-nowrap';
            statusBtn.innerHTML = '<i class="fa-solid fa-circle-xmark text-lg"></i> <span id="statusText">ติดลูกค้า (ไม่ว่าง)</span>';
        }
    });

    // 2. ฟังก์ชันอัปเดตตาราง UI
    function renderTable(bookings) {
        const tbody = document.getElementById('queueTableBody');
        document.getElementById('queueCount').innerText = `${bookings ? bookings.length : 0} คิว`;
        
        if (!bookings || bookings.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="5" class="p-12 text-center text-gray-400 font-medium bg-gray-50/50">
                        <div class="flex flex-col items-center justify-center">
                            <i class="fa-regular fa-face-smile-wink text-5xl mb-4 text-gray-300"></i>
                            <span class="text-lg">ว่างสบาย! ไม่มีคิวรอในขณะนี้</span>
                        </div>
                    </td>
                </tr>
            `;
            return;
        }

        let html = '';
        bookings.forEach((booking) => {
            // ป้องกันกรณีเวลาไม่มี หรือ format ผิด
            let timeStr = booking.bookingTime || '-';
            if (booking.createdAt && typeof booking.createdAt.toDate === 'function') {
                const dateObj = booking.createdAt.toDate();
                timeStr = dateObj.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' });
            }

            html += `
                <tr class="hover:bg-blue-50/30 transition-colors group">
                    <td class="p-4 text-center">
                        <span class="inline-block bg-white text-blue-800 font-black px-4 py-1.5 rounded-lg border border-gray-200 shadow-sm text-lg">${booking.queueId}</span>
                    </td>
                    <td class="p-4 font-semibold text-gray-800 text-lg">
                        ${booking.firstName} ${booking.lastName || ''}
                    </td>
                    <td class="p-4 text-gray-600">
                        <span class="font-medium bg-gray-100 px-3 py-1 rounded-full text-sm border border-gray-200">${booking.serviceName}</span>
                    </td>
                    <td class="p-4 text-center text-gray-500 font-mono text-sm font-semibold">
                        ${timeStr}
                    </td>
                    <td class="p-4 text-center">
                        <div class="flex justify-center gap-2 opacity-100 md:opacity-50 group-hover:opacity-100 transition-opacity">
                            <button onclick="callQueue(this, '${booking.id}', '${booking.queueId}', '${booking.lineUserId || ''}')" class="bg-green-500 hover:bg-green-600 active:bg-green-700 text-white px-3 py-2 rounded-lg shadow-sm hover:shadow-md transition-all flex items-center gap-1.5 text-sm font-bold" title="เรียกคิวนี้">
                                <i class="fa-solid fa-bullhorn"></i> <span class="hidden md:inline">เรียกคิว</span>
                            </button>
                        </div>
                    </td>
                </tr>
            `;
        });
        tbody.innerHTML = html;
    }

    // 2.5 ฟังก์ชันอัปเดตตารางคิวที่กำลังให้บริการ (Serving)
    function renderServingTable(bookings) {
        const tbody = document.getElementById('servingTableBody');
        document.getElementById('servingCount').innerText = `${bookings ? bookings.length : 0} คิว`;
        
        if (!bookings || bookings.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="5" class="p-8 text-center text-gray-400 font-medium bg-gray-50/50">
                        ยังไม่มีคิวที่กำลังให้บริการ
                    </td>
                </tr>
            `;
            return;
        }

        let html = '';
        bookings.forEach((booking) => {
            html += `
                <tr class="hover:bg-blue-50/30 transition-colors group bg-blue-50/10">
                    <td class="p-4 text-center">
                        <span class="inline-block bg-blue-600 text-white font-black px-4 py-1.5 rounded-lg shadow-sm text-lg animate-pulse">${booking.queueId}</span>
                    </td>
                    <td class="p-4 font-bold text-gray-800 text-lg">
                        ${booking.firstName} ${booking.lastName || ''}
                    </td>
                    <td class="p-4 text-gray-600">
                        <span class="font-medium bg-gray-100 px-3 py-1 rounded-full text-sm border border-gray-200">${booking.serviceName}</span>
                    </td>
                    <td class="p-4 text-center font-bold text-blue-700">
                        ${booking.barber || '-'}
                    </td>
                    <td class="p-4 text-center">
                        <button onclick="completeQueue(this, '${booking.id}', '${booking.queueId}')" class="bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white px-4 py-2.5 rounded-xl shadow-md hover:shadow-lg transition-all flex items-center justify-center gap-2 text-sm font-bold mx-auto w-full">
                            <i class="fa-solid fa-check-double"></i> <span class="hidden sm:inline">เสร็จสิ้นงาน</span>
                        </button>
                    </td>
                </tr>
            `;
        });
        tbody.innerHTML = html;
    }

    // 3. Action: เรียกคิว (เปลี่ยน status เป็น 'serving')
    async function callQueue(btn, docId, queueId, lineUserId) {
        const result = await Swal.fire({
            title: `เรียกคิว ${queueId}?`,
            text: "ระบบจะเรียกคิวและแสดงผลบนหน้าจอทีวี",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#22c55e',
            cancelButtonColor: '#ef4444',
            confirmButtonText: '<i class="fa-solid fa-bullhorn"></i> ยืนยันเรียกคิว',
            cancelButtonText: 'ยกเลิก'
        });
        
        if (!result.isConfirmed) return;

        const currentBarber = document.getElementById('currentBarberSelect').value;
        const originalText = btn.innerHTML;

        if (typeof db !== 'undefined' && db !== null && docId !== 'mock') {
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
            btn.classList.add('opacity-70', 'cursor-not-allowed');

            try {
                await db.collection("bookings").doc(docId).update({
                    status: 'serving',
                    barber: currentBarber,
                    updatedAt: firebase.firestore.FieldValue.serverTimestamp()
                });
                
                // ยิง LINE Notify Call แบบ Asynchronous ถ้ามี lineUserId
                if (lineUserId) {
                    try {
                        const notifyUrl = '/api/notify/call';

                        const response = await fetch(notifyUrl, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                queueNumber: queueId,
                                lineUserId: lineUserId
                            })
                        });
                        if (!response.ok) {
                            console.warn("LINE Notify warning: API returned", response.status);
                        }
                    } catch (notifyErr) {
                        console.error("Error triggering LINE notify:", notifyErr);
                    }
                }

                Swal.fire({
                    title: 'เรียกคิวสำเร็จ!',
                    text: `คิว ${queueId} ถูกย้ายไปที่รายการกำลังให้บริการ`,
                    icon: 'success',
                    timer: 2000,
                    showConfirmButton: false
                });
            } catch (err) {
                console.error("Error updating queue: ", err);
                Swal.fire('ข้อผิดพลาด', err.message, 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
                btn.classList.remove('opacity-70', 'cursor-not-allowed');
            }
        } else {
            Swal.fire('จำลองโหมด Mock', `เรียกคิว ${queueId} โดยช่าง ${currentBarber}`, 'success');
        }
    }

    // 4. Action: สร้างคิวทดสอบ (ไม่ต้องสลับหน้า)
    async function createTestQueue() {
        let queueId = 'T001'; // Default

        if (typeof db !== 'undefined' && db !== null) {
            try {
                const counterRef = db.collection('settings').doc('queueCounter');
                
                await db.runTransaction(async (transaction) => {
                    const counterDoc = await transaction.get(counterRef);
                    let newNumber = 1;
                    
                    if (counterDoc.exists) {
                        newNumber = (counterDoc.data().currentNumber || 0) + 1;
                    }
                    
                    queueId = 'T' + String(newNumber).padStart(3, '0');
                    
                    transaction.set(counterRef, {
                        currentNumber: newNumber,
                        lastUpdated: firebase.firestore.FieldValue.serverTimestamp()
                    }, { merge: true });

                    const bookingData = {
                        queueId: queueId,
                        firstName: 'ลูกค้าทดสอบ',
                        lastName: 'ลำดับ ' + queueId,
                        phone: '0800000000',
                        serviceName: 'ตัดผม',
                        servicePrice: 200,
                        barber: 'ยังไม่ระบุ',
                        status: 'pending',
                        createdAt: firebase.firestore.FieldValue.serverTimestamp()
                    };

                    const newBookingRef = db.collection('bookings').doc();
                    transaction.set(newBookingRef, bookingData);
                });
                console.log(`Created test queue: ${queueId}`);
            } catch (err) {
                console.error("Error creating test queue: ", err);
                alert("❌ เกิดข้อผิดพลาดในการสร้างคิวจำลอง: " + err.message);
            }
        } else {
            // โหมด Mock
            mockData.push({ id: 'mock_'+randomNum, queueId: queueId, firstName: 'ลูกค้าทดสอบ', lastName: 'เบอร์ '+randomNum, serviceName: 'ตัดผม', bookingTime: new Date().toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' }) });
            renderTable(mockData);
        }
    }

    // 5. Action: เสร็จสิ้นคิว (เปลี่ยน status เป็น 'completed')
    async function completeQueue(btn, docId, queueId) {
        const result = await Swal.fire({
            title: `เสร็จสิ้นคิว ${queueId}?`,
            text: "คิวนี้จะถูกบันทึกเป็นรายการที่เสร็จสิ้นและลบออกจากหน้าจอช่าง",
            icon: 'info',
            showCancelButton: true,
            confirmButtonColor: '#3b82f6',
            cancelButtonColor: '#6b7280',
            confirmButtonText: '<i class="fa-solid fa-check"></i> ยืนยันจบงาน',
            cancelButtonText: 'ยกเลิก'
        });

        if (!result.isConfirmed) return;

        const originalText = btn.innerHTML;

        if (typeof db !== 'undefined' && db !== null && docId !== 'mock') {
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
            btn.classList.add('opacity-70', 'cursor-not-allowed');

            try {
                await db.collection("bookings").doc(docId).update({
                    status: 'completed',
                    completedAt: firebase.firestore.FieldValue.serverTimestamp()
                });
                Swal.fire({
                    title: 'จบงานสำเร็จ!',
                    text: `คิว ${queueId} เสร็จสิ้นแล้ว`,
                    icon: 'success',
                    timer: 1500,
                    showConfirmButton: false
                });
            } catch (err) {
                console.error("Error completing queue: ", err);
                Swal.fire('ข้อผิดพลาด', err.message, 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
                btn.classList.remove('opacity-70', 'cursor-not-allowed');
            }
        } else {
            Swal.fire('จำลองโหมด Mock', `ปิดคิว ${queueId} เสร็จสิ้นแล้ว!`, 'success');
            mockData = mockData.filter(b => b.queueId !== queueId);
            renderTable(mockData);
            renderServingTable([]);
        }
    }

    // ข้อมูลจำลองสำหรับทดสอบ (กรณีไม่มี DB)
    let mockData = [
        { id: 'mock', queueId: 'A125', firstName: 'สมชาย', lastName: 'รักดี', serviceName: 'ตัดผม (200฿)', bookingTime: '10:00' },
        { id: 'mock', queueId: 'A126', firstName: 'สมหญิง', lastName: '', serviceName: 'ตัดผม + โกนหนวด (250฿)', bookingTime: '10:15' },
        { id: 'mock', queueId: 'A127', firstName: 'วิชัย', lastName: 'ใจตรง', serviceName: 'ตัดผม (200฿)', bookingTime: '10:30' },
        { id: 'mock', queueId: 'A128', firstName: 'มาริโอ้', lastName: 'เมาเร่อ', serviceName: 'ตัดผม (200฿)', bookingTime: '10:45' }
    ];

    // 6. โหลดข้อมูล Real-time จาก Firebase
    let unsubscribePending = null;

    if (typeof db !== 'undefined' && db !== null) {
        unsubscribePending = db.collection("bookings")
            .where("status", "in", ["pending", "calling", "serving"])
            .onSnapshot((snapshot) => {
                const pendingBookings = [];
                const servingBookings = [];
                snapshot.forEach((doc) => {
                    const data = doc.data();
                    const b = { id: doc.id, ...data };
                    
                    if (data.status === 'pending') {
                        pendingBookings.push(b);
                    } else if (data.status === 'calling' || data.status === 'serving') {
                        servingBookings.push(b);
                    }
                });
                
                // เรียงลำดับคิว pending
                pendingBookings.sort((a,b) => {
                    const timeA = a.createdAt?.toDate ? a.createdAt.toDate().getTime() : new Date(a.createdAt || 0).getTime();
                    const timeB = b.createdAt?.toDate ? b.createdAt.toDate().getTime() : new Date(b.createdAt || 0).getTime();
                    return timeA - timeB; // Ascending (เก่าไปใหม่)
                });

                // เรียงลำดับคิว serving (เรียกก่อนขึ้นก่อน)
                servingBookings.sort((a,b) => {
                    const timeA = a.updatedAt?.toDate ? a.updatedAt.toDate().getTime() : new Date(a.updatedAt || 0).getTime();
                    const timeB = b.updatedAt?.toDate ? b.updatedAt.toDate().getTime() : new Date(b.updatedAt || 0).getTime();
                    return timeB - timeA; // Descending (ใหม่สุดขึ้นก่อน)
                });
                
                renderTable(pendingBookings);
                renderServingTable(servingBookings);
            }, (error) => {
                console.error("Error listening to bookings: ", error);
                renderTable(mockData); // Fallback
                renderServingTable([]);
            });

        // [Memory Leak Prevention] ป้องกัน Memory leak เมื่อออกจากหน้านี้
        window.addEventListener('beforeunload', () => {
            if (unsubscribePending) {
                unsubscribePending();
            }
        });
    } else {
        // ใช้ข้อมูลจำลองถ้าไม่มี DB
        document.getElementById('firebaseErrorBanner').classList.remove('hidden');
        setTimeout(() => {
            renderTable(mockData);
        }, 800);
    }
</script>

